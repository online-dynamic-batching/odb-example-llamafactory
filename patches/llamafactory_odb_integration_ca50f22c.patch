+"""
+Lazy QMDB DataLoader integration module.
+
+This module provides the main entry point for creating lazy-loading
+DataLoaders with QMDB (TMDB/LMDB) data sources.
+
+Usage:
+    from llamafactory.data.lazy import get_lazy_qmdb_dataloader
+
+    dataloader = get_lazy_qmdb_dataloader(
+        config_path="path/to/config.yaml",
+        template=template,
+        tokenizer=tokenizer,
+        processor=processor,
+        training_args=training_args,
+    )
+"""
+
+from typing import TYPE_CHECKING, List, Optional, Union
+
+import torch
+from torch.utils.data import DataLoader, DistributedSampler, RandomSampler
+
+from .config import (
+    QMDBDatasetConfig,
+    QMDBLoaderConfig,
+    parse_qmdb_config,
+    parse_qmdb_yaml_datasets,
+)
