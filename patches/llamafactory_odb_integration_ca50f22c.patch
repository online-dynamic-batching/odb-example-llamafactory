+++ b/src/llamafactory/data/qmdb/reader.py
@@ -0,0 +1,222 @@
+from typing import Optional, List
+import os
+from io import BytesIO
+from base64 import b64decode
+import pickle
+from PIL import Image
+from .tmdb import TMDB, TMDB_EXTS
+from .lmdbs import LMDBS, LMDB_EXTS
+
+try:
+    import decord
+except ImportError:
+    pass
+
+
+def load(path: str, image_dir: Optional[str] = None, task: Optional[str] = None, extra_path: Optional[str] = None):
+    def get_QMDBReader(path):
+        if os.path.isdir(path):
+            exts = {os.path.splitext(file)[1] for file in os.listdir(path)}
+        else:
+            exts = {os.path.splitext(path)[1]}
+
+        if '.tmdb' in exts:
+            return TableQMDBReader
+        elif 'qmdbx' in path or '.qmdbx' in exts:
+            return PickleQMDBReader
+        else:
+            raise ValueError(f"Unrecognized data in path: {path}")
+
+    QMDBReader = get_QMDBReader(path)
+    return QMDBReader.load(path, image_dir, task, extra_path)
+
+
+class BaseQMDBReader:
+    DB = None
+    exts: set = None
+    keys: List = None
+
+    def __init__(self, data, image_dir: Optional[str] = None, task: Optional[str] = None, extra_data=None):
+        self.data = data
+        self.path = data.path
+        self.image_dir = image_dir
+        self.task = task
+        self.extra_data = extra_data
+
+    @classmethod
+    def load(cls, path: str,
+             image_dir: Optional[str] = None, task: Optional[str] = None, extra_path: Optional[str] = None, *,
+             map_size: int = 4*1024*1024*1024, subdir: Optional[bool] = None, readonly: bool = True,
+             max_readers: int = 8192, max_spare_txns: int = 64, lock: bool = False,
+             **kwargs):
+        data = cls.DB.open(path,
+                           map_size=map_size, subdir=subdir, readonly=readonly,
+                           max_readers=max_readers, max_spare_txns=max_spare_txns, lock=lock,
+                           exts=cls.exts, **kwargs)
+
+        if extra_path is None:
+            extra_data = None
+        else:
+            extra_data = LMDBS.open(extra_path,
+                                    map_size=map_size, subdir=subdir, readonly=readonly, max_readers=max_readers,
+                                    max_spare_txns=max_spare_txns, lock=lock, **kwargs)
+
+        return cls(data, image_dir, task, extra_data=extra_data)
+
+    def get(self, key, default=None):
+        record = self.read_data(key)
+        record = self.process(record)
+
+        if record is None:
+            return default
+        else:
+            return record
+
+    def __getitem__(self, index):
+        return self.get(self.keys[index])
+
+    def iter(self, keys: bool = True, values: bool = True, reverse: bool = False):
+        for item in self.data.iter(keys, values, reverse):
+            if keys and values:
+                key, value = item
+            elif keys:
+                key, value = item, None
+            elif values:
+                key, value = None, item
+            else:
+                key, value = None, None
+
+            if value is not None:
+                value = self.process(value)
+
+            if keys and values:
+                yield key, value
+            elif keys:
+                yield key
+            else:
+                yield value
+
+    def process(self, record):
+        if record is None:
+            return record
+
+        if 'images' in record:
+            record['images'] = [self.read_img(image) for image in record['images']]
+        elif 'image' in record:
+            record['images'] = [self.read_img(record.pop('image'))]
+        elif 'video' in record:
+            record['video'] = self.read_video(record['video'])
+
+        return record
+
+    def read_data(self, key):
+        return self.data.get(key)
+
+    def read_img(self, image):
+        if isinstance(image, str):
+            if image.startswith('extra_key: '):
+                image = image[len('extra_key: '):]
+                image = {'image': Image.open(BytesIO(self.extra_data.get(image))).convert('RGB')}
+            elif image.startswith('base64: '):
+                image = image[len('base64: '):]
+                image = {'image': Image.open(BytesIO(b64decode(image))).convert('RGB')}
+            else:
+                image_path = self._parse_image_path(self.image_dir, image)
+                image = {'image': Image.open(image_path).convert('RGB'),
+                         'path': image_path}
+        elif isinstance(image, bytes):
+            image = {'image': Image.open(BytesIO(image)).convert('RGB')}
+        elif isinstance(image, dict):
+            if 'image_b64' in image:
+                image['image'] = Image.open(BytesIO(b64decode(image.pop('image_b64')))).convert('RGB')
+            elif 'image_bytes' in image:
+                image['image'] = Image.open(BytesIO(image.pop('image_bytes'))).convert('RGB')
+            elif 'extra_key' in image:
+                image['image'] = Image.open(BytesIO(self.extra_data.get(image.pop('extra_key')))).convert('RGB')
+            elif 'path' in image:
+                image_path = self._parse_image_path(self.image_dir, image['path'])
+                image['image'] = Image.open(image_path).convert('RGB')
+                image['path'] = image_path
+            else:
+                raise ValueError(f"Cannot find image_b64|image_bytes|extra_key|path in image info keys: {image.keys()}")
+        else:
+            raise ValueError(f"Wrong image type: required str|bytes|dict but got {type(image)}")
+
+        return image
+
+    def read_video(self, video):
+        if isinstance(video, str):
+            video_path = self._parse_image_path(self.image_dir, video)
+            if video_path.endswith('.gif'):
+                video = {'gif': Image.open(video_path), 'path': video_path}
+            elif os.path.isdir(video_path):
+                image_exts = {'.jpg', '.jpeg', '.png'}
+                images = [os.path.join(video_path, f) for f in os.listdir(video_path)
+                          if os.path.splitext(f)[1] in image_exts]
+                video = {'images': images, 'path': video_path}
+            else:
+                video = {'video': decord.VideoReader(video_path, ctx=decord.cpu(0), num_threads=1),
+                         'path': video_path}
+        else:
+            raise ValueError(f"Wrong video type: required str but got {type(video)}")
+
+        return video
+
+    @staticmethod
+    def _parse_image_path(image_dir, image_file):
+        if image_dir is None or image_file.startswith('/'):
+            image_path = image_file
+        else:
+            image_dir = image_dir.rstrip('/')
+
+            if os.path.basename(image_dir) == image_file.split('/')[0]:
+                image_file = '/'.join(image_file.split('/')[1:])
+
+            image_path = os.path.join(image_dir, image_file)
+
+        return image_path
+
+    def __len__(self):
+        return len(self.keys)
+
+    def close(self):
+        self.data.close()
+        if self.extra_data is not None:
+            self.extra_data.close()
+
+    def __del__(self):
+        self.close()
+
+
+class TableQMDBReader(BaseQMDBReader):
+    DB = TMDB
+    exts = TMDB_EXTS
+
+    def __init__(self, *args, **kwargs):
+        super().__init__(*args, **kwargs)
+
+        self.keys = list(self.data.keys())
+
+
+class PickleQMDBReader(BaseQMDBReader):
+    DB = LMDBS
+    exts = LMDB_EXTS | {'.qmdbx'}
+
+    def __init__(self, *args, **kwargs):
+        super().__init__(*args, **kwargs)
+
+        not_extras = [False if '.extra.' in os.path.basename(path) else True for path in self.data.env.paths]
+        self.keys = [k for k, i in self.data.txn.map.items() if not_extras[i]]
+
+    def read_data(self, key):
+        record = self.data.get(key)
+        if record is None:
+            return record
+        record = RestrictedUnpickler(BytesIO(record)).load()
+
+        return record
+
+
+class RestrictedUnpickler(pickle.Unpickler):
+    def find_class(self, module, name):
+        raise pickle.UnpicklingError(f"Attempting to unpickle unknown class: {module}.{name}")
