+"""
+Lazy loading module for QMDB (TMDB/LMDB) data sources.
+
+Features:
+- Lazy loading: Only store keys, load data on-demand
+- On-the-fly tokenization
+- Compatible with Qwen3-VL and other multimodal models
+- Support for OLG (Online Length Grouped) and ODB (Online Dynamic Batch) DataLoaders
+"""
+
+from .config import QMDBDatasetConfig, parse_qmdb_config
+from .dataset import LazyQMDBDataset
+from .loader import get_lazy_qmdb_dataloader, create_lazy_collator
+from .collator import SimpleCollator, create_simple_collator
+
+
+__all__ = [
+    "QMDBDatasetConfig",
+    "parse_qmdb_config",
+    "LazyQMDBDataset",
+    "get_lazy_qmdb_dataloader",
+    "create_lazy_collator",
+    "SimpleCollator",
+    "create_simple_collator",
+]
