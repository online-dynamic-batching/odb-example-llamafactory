index 00000000..80ac0870
--- /dev/null
+++ b/src/llamafactory/data/qmdb/tmdb.py
@@ -0,0 +1,686 @@
+import pickle
+from typing import Optional, Dict, List, Set, Any
+import os
+import time
+from io import BytesIO
+from collections import OrderedDict
+import struct
+import glob
+import lmdb
+
+
+TMDB_EXTS = {'.tmdb'}
+
+
+DType_bytes = 0
+DType_bool = 1
+DType_int = 2
+DType_float = 3
+DType_str = 4
+DType_pickle = 5
+
+
+DTypeMapping = {
+    bytes: DType_bytes,
+    bool: DType_bool,
+    int: DType_int,
+    float: DType_float,
+    str: DType_str,
+    list: DType_pickle,
+    dict: DType_pickle,
+    tuple: DType_pickle
+}
+
+DTypes = set(DTypeMapping.values())
+
+
+class DataCoding:
+    Int_Length = 8
+    Float_Length = 'f'
+
+    class IndexCoding:
+        @staticmethod
+        def encode(data: int, length) -> bytes:
+            return data.to_bytes(length, 'little')
+
+        @staticmethod
+        def decode(data: bytes) -> int:
+            return int.from_bytes(data, 'little')
+
+    class TimeCoding:
+        @staticmethod
+        def encode(data: int) -> bytes:
+            return data.to_bytes(4, 'little')
+
+        @staticmethod
+        def decode(data: Optional[bytes]) -> int:
+            return None if data is None else int.from_bytes(data, 'little')
+
+    class BytesCoding:
+        @staticmethod
+        def encode(data: bytes) -> bytes:
+            return data
+
+        @staticmethod
+        def decode(data: bytes) -> bytes:
+            return data
+
+    class BoolCoding:
+        @staticmethod
+        def encode(data: bool) -> bytes:
+            return bytes(data)
+
+        @staticmethod
+        def decode(data: bytes) -> bool:
+            return bool(data)
+
+    class IntCoding:
+        @staticmethod
+        def encode(data: int, length=None, signed=True) -> bytes:
+            if length is None:
+                length = DataCoding.Int_Length
+            return data.to_bytes(length, 'little', signed=signed)
+
+        @staticmethod
+        def decode(data: bytes, signed=True) -> int:
+            return int.from_bytes(data, 'little', signed=signed)
+
+    class FloatCoding:
+        @staticmethod
+        def encode(data: float, length=None) -> bytes:
+            if length is None:
+                length = DataCoding.Float_Length
+            return struct.pack(length, data)
+
+        @staticmethod
+        def decode(data: bytes, length=None) -> float:
+            if length is None:
+                length = DataCoding.Float_Length
+            return struct.unpack(length, data)[0]
+
+    class StrCoding:
+        @staticmethod
+        def encode(data: str) -> bytes:
+            return data.encode()
+
+        @staticmethod
+        def decode(data: bytes) -> str:
+            return data.decode()
+
+    class PickleCoding:
+        @staticmethod
+        def encode(data: Any) -> bytes:
+            return pickle.dumps(data, protocol=4)
+
+        @staticmethod
+        def decode(data: bytes) -> Any:
+            return DataCoding.RestrictedUnpickler(BytesIO(data)).load()
+
+    class RestrictedUnpickler(pickle.Unpickler):
+        def find_class(self, module, name):
+            raise pickle.UnpicklingError(f"Attempting to unpickle unknown class: {module}.{name}")
+
+    EncodeBook = {
+        DType_bytes: BytesCoding.encode,
+        DType_bool: BoolCoding.encode,
+        DType_int: IntCoding.encode,
+        DType_float: FloatCoding.encode,
+        DType_str: StrCoding.encode,
+        DType_pickle: PickleCoding.encode
+    }
+
+    DecodeBook = {
+        DType_bytes: BytesCoding.decode,
+        DType_bool: BoolCoding.decode,
+        DType_int: IntCoding.decode,
+        DType_float: FloatCoding.decode,
+        DType_str: StrCoding.decode,
+        DType_pickle: PickleCoding.decode
+    }
+
+    @staticmethod
+    def encode(data: Any, dtype: int, **kwargs) -> bytes:
+        encode_fn = DataCoding.EncodeBook[dtype]
+        return encode_fn(data, **kwargs)
+
+    @staticmethod
+    def decode(data: bytes, dtype: int, **kwargs) -> Any:
+        decode_fn = DataCoding.DecodeBook[dtype]
+        return decode_fn(data, **kwargs)
+
+
+def alphanum_path_key(s: str):
+    """Use to sort string by numbers in it, useful when numbers in string are not matched in digit (1 and 001)."""
+    s = os.path.splitext(s)[0]
+    sections = []
+    section = ''
+    is_digit = False
+    for c in s:
+        if c.isdigit() == is_digit:
+            section += c
+        else:
+            if is_digit:
+                section = int(section)
+            sections.append(section)
+            section, is_digit = c, c.isdigit()
+    if is_digit:
+        section = int(section)
+    sections.append(section)
+    return sections
+
+
+class Column:
+    dtype_index = 0
+
+    def __init__(self, db, dtype):
+        if dtype not in DTypes:
+            raise ValueError(f"Unknown column dtype: {dtype}")
+        self.db = db
+        self.dtype = dtype
+
+    @classmethod
+    def new(cls, env: lmdb.Environment, column_name: str, dtype: int, txn: lmdb.Transaction):
+        db = env.open_db(column_name.encode(), txn=txn, reverse_key=True, integerkey=True, create=True)
+
+        if dtype not in DTypes:
+            raise ValueError(f"Unknown column dtype: {dtype}")
+        dtype_index = DataCoding.IndexCoding.encode(Column.dtype_index, LMDBTable.Index_Length)
+        flag = txn.put(dtype_index, DataCoding.IntCoding.encode(dtype, length=1), db=db)
+        if not flag:
+            raise RuntimeError("Failed to put dtype when creating column.")
+
+        return Column(db, dtype)
+
+    @classmethod
+    def open(cls, env: lmdb.Environment, column_name: str):
+        db = env.open_db(column_name.encode(), reverse_key=True, integerkey=True, create=False)
+
+        dtype_index = DataCoding.IndexCoding.encode(Column.dtype_index, LMDBTable.Index_Length)
+        with env.begin(write=False) as txn:
+            dtype = txn.get(dtype_index, None, db=db)
+        if dtype is None:
+            raise ValueError("Column dtype is not defined.")
+        dtype = DataCoding.IntCoding.decode(dtype)
+
+        return cls(db, dtype)
+
+
+class LMDBTable:
+    Index_key = b'.Index'
+    Map_key = b'.Map'
+    CreateTime_key = b'.CreateTime'
+    UpdateTime_key = b'.UpdateTime'
+    Index_Length = 4
+
+    def __init__(self, path: str, env: lmdb.Environment):
+        self.path = path
+        self.env = env
+
+        self._init_table()
+
+        self.columns = OrderedDict((c, Column.open(env, c)) for c in self.column_names)
+
+        self._keys_file = self.path + '-keys'
+        self.keys = self._init_keys()
+        self._keys_buffer = []
+        self._has_pop_keys = False
+
+        self._txn = None
+        if self.readonly:
+            self._txn = self.txn
+
+    def _init_table(self):
+        if self.env.stat()['entries'] == 0:
+            with self.env.begin(write=True) as txn:
+                self.Index = self.env.open_db(self.Index_key, txn, reverse_key=True, integerkey=True)
+                self.Map = self.env.open_db(self.Map_key, txn)
+                self.CreateTime = self.env.open_db(self.CreateTime_key, txn, reverse_key=True, integerkey=True)
+                self.UpdateTime = self.env.open_db(self.UpdateTime_key, txn, reverse_key=True, integerkey=True)
+        else:
+            self.Index = self.env.open_db(self.Index_key, reverse_key=True, integerkey=True, create=False)
+            self.Map = self.env.open_db(self.Map_key, create=False)
+            self.CreateTime = self.env.open_db(self.CreateTime_key, reverse_key=True, integerkey=True, create=False)
+            self.UpdateTime = self.env.open_db(self.UpdateTime_key, reverse_key=True, integerkey=True, create=False)
+
+    @property
+    def txn(self):
+        if self._txn is None:
+            self._txn = self.env.begin(write=not self.readonly)
+        return self._txn
+
+    @staticmethod
+    def open(path: str, map_size: int = 4*1024*1024*1024,
+             subdir: Optional[bool] = None, readonly: bool = True, *args, max_dbs=128, **kwargs):
+        subdir = bool(subdir)
+        assert subdir is False, "'subdir' must be None or False."
+
+        env = lmdb.Environment(path, map_size, subdir, readonly, *args, max_dbs=max_dbs, **kwargs)
+
+        return LMDBTable(path, env)
+
+    def _init_keys(self):
+        if os.path.exists(self._keys_file):
+            with open(self._keys_file) as f:
+                keys = f.read().splitlines()
+        else:
+            keys = None
+
+        txn = self.env.begin(self.Map, write=False)
+        if keys is None or len(keys) != txn.stat()['entries']:
+            keys = []
+            for key, idx in txn.cursor().iternext():
+                keys.append((DataCoding.IndexCoding.decode(idx), key.decode()))
+            txn.abort()
+            keys = sorted(keys, key=lambda ik: ik[0])
+            keys = [ik[1] for ik in keys]
+            with open(self._keys_file, 'w') as f:
+                f.writelines(k + '\n' for k in keys)
+        else:
+            txn.abort()
+
+        keys = OrderedDict((k, None) for k in keys)
+
+        return keys
+
+    def get(self, key: str, column_names=None, default=None, get_meta=False):
+        index = self.txn.get(key.encode(), db=self.Map)
+        if index is None:
+            return default
+        if column_names is None:
+            column_names = self.columns.keys()
+
+        record = {}
+        for c in column_names:
+            item = self._get_item(index, c)
+            if item is not None:
+                record[c] = item
+
+        if get_meta:
+            record['.CreateTime'] = DataCoding.TimeCoding.decode(self.txn.get(index, db=self.CreateTime))
+            record['.UpdateTime'] = DataCoding.TimeCoding.decode(self.txn.get(index, db=self.UpdateTime))
+
+        return record
+
+    def _get_item(self, index, column_name):
+        column = self.columns[column_name]
+        item = self.txn.get(index, db=column.db)
+        if item is None:
+            return None
+        item = DataCoding.decode(item, column.dtype)
+
+        return item
+
+    def put(self, key: str, value: dict, overwrite=True, append=False, new_column=False):
+        if key in self.keys:
+            if not overwrite:
+                raise KeyError(f"Key already exists when not overwrite: {key}")
+            if append:
+                raise KeyError(f"Key already exists when append: {key}")
+            index = self.txn.get(key.encode(), db=self.Map)
+            flag = 2
+        else:
+            index = self.new_index
+            flag = 1
+
+        self._put_check(value, new_column)
+
+        for column_name, item in value.items():
+            self._put_item(index, item, column_name, overwrite, append)
+
+        timestamp = int(time.time())
+        if flag == 1:
+            self.keys[key] = None
+            self._keys_buffer.append(key)
+            key_bytes = key.encode()
+            flag_ = self.txn.put(key_bytes, index, db=self.Map, overwrite=False)
+            if not flag_:
+                raise RuntimeError("Conflict in putting a new key: exists in Map.")
+            self.txn.put(index, key_bytes, db=self.Index, append=True)
+            self.txn.put(index, DataCoding.TimeCoding.encode(timestamp), db=self.CreateTime, append=True)
+            self.txn.put(index, DataCoding.TimeCoding.encode(timestamp), db=self.UpdateTime, append=True)
+        else:
+            self.txn.put(index, DataCoding.TimeCoding.encode(timestamp), db=self.UpdateTime, overwrite=overwrite)
+
+        return flag
+
+    def _put_check(self, value: dict, new_column=False):
+        for column_name, item in value.items():
+            if item is None:
+                continue
+
+            dtype = DTypeMapping.get(type(item), None)
+            if dtype is None:
+                raise ValueError(f"Unsupported item type: {type(item)}, in column: {column_name}")
+
+            column = self.columns.get(column_name, None)
+            if column is None:
+                if not new_column:
+                    raise ValueError(f"Column does not exist when new_column=False: {column_name}")
+            else:
+                if dtype != column.dtype:
+                    raise ValueError(f"Item type {dtype} does not match column type {column.dtype} "
+                                     f"in column: {column_name}")
+
+    def _put_item(self, index, item, column_name, overwrite=True, append=False):
+        if item is None:
+            return
+
+        dtype = DTypeMapping[type(item)]
+
+        if column_name in self.columns:
+            column = self.columns[column_name]
+        else:
+            column = Column.new(self.env, column_name, dtype, self.txn)
+            self.columns[column_name] = column
+
+        item = DataCoding.encode(item, column.dtype)
+
+        flag = self.txn.put(index, item, db=column.db, overwrite=overwrite, append=append)
+        if not flag:
+            raise RuntimeError(f"Failed to put item in column: {column_name}")
+
+    def pop(self, key: str, column_names=None):
+        index = self.txn.get(key.encode(), db=self.Map)
+        if index is None:
+            return None
+        if column_names is None:
+            column_names = self.columns.keys()
+        for c in column_names:
+            self._pop_item(index, c)
+        self.keys.pop(key)
+        self._has_pop_keys = True
+        self.txn.pop(index, db=self.Index)
+        self.txn.pop(key.encode(), db=self.Map)
+
+    def _pop_item(self, index, column_name):
+        column = self.columns[column_name]
+        self.txn.pop(index, db=column.db)
+
+    def drop_column(self, column_name):
+        column = self.columns.pop(column_name, None)
+        if column is None:
+            return
+        self.txn.drop(column.db, delete=True)
+
+    def iter(self, keys: bool = True, values: bool = True, reverse: bool = False):
+        assert keys or values, "keys and values cannot both be False."
+
+        if reverse:
+            iterator = self.txn.cursor(db=self.Index).iterprev(keys=False)
+        else:
+            iterator = self.txn.cursor(db=self.Index).iternext(keys=False)
+
+        for key in iterator:
+            key = key.decode()
+            if values:
+                value = self.get(key)
+
+            if keys and values:
+                yield key, value
+            elif keys:
+                yield key
+            else:
+                yield value
+
+    def commit(self):
+        if self._txn is not None:
+            self._txn.commit()
+            self._txn = None
+
+        if self._has_pop_keys:
+            with open(self._keys_file, 'w') as f:
+                f.writelines(k + '\n' for k in self.keys)
+        else:
+            with open(self._keys_file, 'a') as f:
+                f.writelines(k + '\n' for k in self._keys_buffer)
+
+        self.abort()
+
+    def abort(self):
+        if self._txn is not None:
+            self._txn.abort()
+            self._txn = None
+        self._keys_buffer.clear()
+        self._has_pop_keys = False
+
+    @property
+    def readonly(self):
+        return self.env.flags()['readonly']
+
+    @property
+    def column_names(self):
+        column_names = []
+        with self.env.begin(write=False) as txn:
+            for key in txn.cursor().iternext(values=False):
+                if not key.startswith(b'.'):
+                    column_names.append(key.decode())
+
+        return column_names
+
+    @property
+    def last_index(self):
+        with self.txn.cursor(self.Index) as curs:
+            last_index = DataCoding.IndexCoding.decode(curs.key()) if curs.last() else 63
+
+        return last_index
+
+    @property
+    def new_index(self):
+        return DataCoding.IndexCoding.encode(self.last_index + 1, LMDBTable.Index_Length)
+
+    def close(self):
+        self.abort()
+        self.columns.clear()
+        self.env.close()
+
+    def __len__(self):
+        with self.env.begin(self.Map, write=False) as txn:
+            entries = txn.stat()['entries']
+
+        return entries
+
+    def __del__(self):
+        self.close()
+
+
+class ExtendLMDBTable:
+    def __init__(self, path: str, tables: List[LMDBTable], map_size: int):
+        self.path = path
+        self.tables = tables
+        self.map_size = map_size
+        self._buffer = []
+
+        self.mapping = self._init_mapping()
+
+    @classmethod
+    def open(cls, path: str, map_size: int = 4*1024*1024*1024, subdir: Optional[bool] = None, readonly: bool = True,
+             *args, exts: Optional[Set[str]] = None, **kwargs):
+        paths = cls._parse_path(path, exts)
+        tables = [LMDBTable.open(p, map_size, subdir, readonly, *args, **kwargs) for p in paths]
+
+        return cls(path, tables, map_size)
+
+    @classmethod
+    def dump(cls, data: Dict[str, Dict[str, Any]], path: str, map_size: int = 4*1024*1024*1024,
+             subdir: Optional[bool] = None, readonly: bool = False, *args, commit_size=256, **kwargs):
+        assert isinstance(data, dict), f"dump data must be a dictionary, rather than a {type(data)}."
+        for value in data.values():
+            assert isinstance(value, dict), f"value in data must be a dictionary, rather than a {type(value)}."
+
+        tmdb = cls.open(path, map_size, subdir, readonly, *args, **kwargs)
+
+        commit_size_ = commit_size - 1
+        for i, (key, value) in enumerate(data.items()):
+            tmdb.put(key, value, append=True, new_column=True)
+            if i % commit_size == commit_size_:
+                tmdb.commit(append=True)
+        tmdb.commit(append=True)
+        tmdb.abort()
+
+    @classmethod
+    def _parse_path(cls, path: str, exts: Optional[Set[str]] = None):
+        if exts is None:
+            exts = TMDB_EXTS
+
+        if isinstance(path, list):
+            paths = path
+        elif glob.has_magic(path):
+            paths = sorted(glob.glob(path), key=alphanum_path_key)
+        elif not os.path.exists(path):
+            paths = [cls._create_path(path)]
+        elif os.path.isdir(path):
+            paths = sorted(glob.glob(os.path.join(path, '*')), key=alphanum_path_key)
+            paths = [p for p in paths if os.path.splitext(p)[1] in exts]
+        else:
+            paths = [path]
+
+        if not len(paths):
+            raise FileNotFoundError(f"Cannot find tmdb files in path: {path}.")
+
+        return paths
+
+    @staticmethod
+    def _create_path(path: str):
+        ext = os.path.splitext(path)[1]
+        if ext == '':
+            folder = path
+            file = os.path.join(path, 'data.tmdb')
+        else:
+            folder = os.path.dirname(path)
+            file = path
+
+        if not os.path.exists(folder):
+            os.mkdir(folder)
+
+        return file
+
+    def _init_mapping(self):
+        mapping = {}
+        _counts = {}
+        for i, table in enumerate(self.tables):
+            for k in table.keys:
+                n = _counts.get(k, 0)
+                _counts[k] = n + 1
+                k = (k, n) if n else k
+                mapping[k] = i
+
+        return mapping
+
+    def _extend_table(self):
+        assert not self.readonly, "Failed to extend_table, cannot extend in readonly mode."
+        assert len(self.tables) > 0, "Failed to extend_table, no existing table."
+        path = self.path if os.path.isfile(self.path) else self.tables[0].path
+        index = len(self.tables)
+
+        _buffer = self._buffer.copy()
+        self.abort()
+
+        dn, fn = os.path.split(path)
+        fn, ext = os.path.splitext(fn)
+        path = f"{dn}/{fn}-{index}{ext}"
+
+        table = LMDBTable.open(path, map_size=self.map_size, subdir=False, readonly=False)
+        self.tables.append(table)
+
+        for key, value in _buffer:
+            self.put(key, value, append=True, new_column=True)
+
+        return index
+
+    def get(self, key: str, column_names: Optional[List[str]] = None, default: Any = None, get_meta: bool = False) \
+            -> Dict[str, Any]:
+        table_index = self.mapping.get(key, None)
+        if table_index is None:
+            return default
+        if isinstance(key, tuple):
+            key = key[0]
+        record = self.tables[table_index].get(key, column_names=column_names, default=default, get_meta=get_meta)
+
+        return record
+
+    def put(self, key: str, value: Dict[str, Any],
+            overwrite: bool = True, append: bool = False, new_column: bool = False) -> int:
+        if append:
+            table_index = len(self.tables) - 1
+        else:
+            table_index = self.mapping.get(key, None)
+            if table_index is None:
+                table_index = len(self.tables) - 1
+        table = self.tables[table_index]
+
+        try:
+            flag = table.put(key, value, overwrite=overwrite, append=append, new_column=new_column)
+        except lmdb.MapFullError:
+            if not append:
+                raise
+            table_index = self._extend_table()
+            table = self.tables[table_index]
+            flag = table.put(key, value, overwrite=overwrite, append=append, new_column=new_column)
+
+        if flag == 1:
+            self.mapping[key] = table_index
+            self._buffer.append((key, value))
+
+        return flag
+
+    def pop(self, key: str, column_names: Optional[List[str]] = None):
+        table_index = self.mapping.get(key, None)
+        if table_index is None:
+            raise KeyError(f"Pop key not found: {key}")
+        self.tables[table_index].pop(key, column_names=column_names)
+
+    def drop_column(self, column_name: Optional[List[str]]):
+        for table in self.tables:
+            table.drop_column(column_name)
+
+    def iter(self, keys: bool = True, values: bool = True, reverse: bool = False):
+        if reverse:
+            tables = self.tables[::-1]
+        else:
+            tables = self.tables
+
+        for table in tables:
+            for item in table.iter(keys, values, reverse):
+                yield item
+
+    def commit(self, append: bool = False):
+        for table in self.tables[:-1]:
+            table.commit()
+        try:
+            self.tables[-1].commit()
+        except lmdb.MapFullError:
+            if not append:
+                raise
+            self._extend_table()
+            self.tables[-1].commit()
+        self._buffer.clear()
+
+    def abort(self):
+        for table in self.tables:
+            table.abort()
+        self._buffer.clear()
+
+    def keys(self):
+        return self.mapping.keys()
+
+    @property
+    def readonly(self):
+        return all(table.readonly for table in self.tables)
+
+    @property
+    def column_names(self):
+        return list(set.union(*(set(table.columns.keys()) for table in self.tables)))
+
+    def close(self):
+        self.abort()
+        for table in self.tables:
+            table.close()
+
+    def __len__(self):
+        return sum(len(table) for table in self.tables)
+
+    def __del__(self):
+        self.close()
+
+
+TMDB = ExtendLMDBTable
