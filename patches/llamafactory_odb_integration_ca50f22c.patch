+def dataset_attr_to_qmdb_config(attr: "DatasetAttr") -> QMDBDatasetConfig:
+    """
+    Convert a DatasetAttr (from dataset_info.json) to QMDBDatasetConfig (for QMDB lazy loader).
+
+    Standard DatasetAttr fields are mapped directly. QMDB-specific fields
+    (image_dir, extra_path, weight, prompt as fixed text) are read from attr.extra.
+
+    Note on "prompt" semantics:
+    - DatasetAttr.prompt is a column name (default "instruction") for alpaca format
+    - QMDBDatasetConfig.prompt is a fixed prompt text (e.g., "Recognize text in the image")
+    - The mapping uses attr.extra.get("prompt") for the fixed prompt text
+    - DatasetAttr.prompt (column name) maps to QMDBDatasetConfig.instruction_key
+    """
+    return QMDBDatasetConfig(
+        name=str(attr),  # dataset_name (tmdb_file path)
+        data_file=attr.dataset_name,  # tmdb_file path stored in dataset_name
+        formatting=attr.formatting,
+        max_samples=attr.num_samples,
+        # Standard columns mapping
+        messages_key=attr.messages or "conversations",
+        images_key=attr.images or "images",
+        # Alpaca column name mapping
+        instruction_key=attr.prompt or "instruction",
+        input_key=attr.query or "input",
+        output_key=attr.response or "output",
