+"""
+Lazy loading QMDB dataset implementation.
+
+Features:
+- Only stores keys in memory, loads data on-demand
+- On-the-fly tokenization and processing
+- Compatible with Qwen3-VL and other multimodal models
+- Seamless integration with LlamaFactory's MultiModalDataCollatorForSeq2Seq
+"""
+
+import os
+import random
+import sys
+from copy import deepcopy
+from typing import TYPE_CHECKING, Any, Dict, List, Optional, Union
+
+import torch
+from torch.utils.data import Dataset
+
+from ...extras.constants import IGNORE_INDEX
+from .config import QMDBDatasetConfig
+
+
+if TYPE_CHECKING:
+    from PIL.Image import Image as ImageObject
+    from transformers import PreTrainedTokenizer, ProcessorMixin
+
+    from ..template import Template
+
+
+class LazyQMDBDataset(Dataset):
+    """
+    Lazy loading dataset for QMDB (TMDB/LMDB) data sources.
+
+    This dataset:
+    - Only stores keys in memory, not the actual data
+    - Loads and processes data on-demand in __getitem__
+    - Returns data compatible with LlamaFactory's MultiModalDataCollatorForSeq2Seq
+    - Supports both image and video modalities
+
+    The returned dict contains:
+    - input_ids: List[int] - tokenized input
+    - attention_mask: List[int] - attention mask (all 1s)
+    - labels: List[int] - labels with IGNORE_INDEX for prompts
+    - images: List[PIL.Image] - raw PIL images for Collator to process
+    - videos: List[...] - raw video data
+    - audios: List[...] - raw audio data (usually empty)
+    """
+
+    def __init__(
+        self,
+        config: QMDBDatasetConfig,
+        template: "Template",
+        tokenizer: "PreTrainedTokenizer",
+        processor: Optional["ProcessorMixin"] = None,
+        cutoff_len: int = 2048,
+        train_on_prompt: bool = False,
+        mask_history: bool = False,
+    ):
+        """
+        Initialize the lazy dataset.
+
+        Args:
+            config: Dataset configuration
+            template: LlamaFactory template (contains mm_plugin)
+            tokenizer: Tokenizer for text encoding
+            processor: Multimodal processor (for Qwen3-VL, etc.)
+            cutoff_len: Maximum sequence length
+            train_on_prompt: Whether to compute loss on prompts
+            mask_history: Whether to mask history turns
+        """
+        self.config = config
+        self.template = template
+        self.tokenizer = tokenizer
+        self.processor = processor
+        self.cutoff_len = cutoff_len
+        self.train_on_prompt = train_on_prompt
+        self.mask_history = mask_history
+
+        # Get mm_plugin from template
+        self.mm_plugin = template.mm_plugin
+
+        # Lazy load: only get keys, don't load data
+        self._init_reader()
+
+    def _init_reader(self):
+        """Initialize the QMDB reader and get keys.
+
+        Important: We only use the reader to get keys, then set it to None.
+        This is critical for multiprocessing/fork safety - LMDB readers
+        cannot be shared across forked processes.
+        """
+        from ..qmdb.reader import load
+
+        # Temporarily create reader just to get keys
+        temp_reader = load(
+            path=self.config.data_file,
+            image_dir=self.config.image_dir,
+            extra_path=self.config.extra_path,
+        )
+
+        # Get all keys
+        self.keys = list(temp_reader.keys)
+
+        # Apply sampling if specified
+        # Use sequential truncation instead of random sampling for reproducibility
+        if self.config.max_samples is not None and self.config.max_samples < len(self.keys):
+            self.keys = self.keys[:self.config.max_samples]
+
+        # Don't store the reader - it will be created lazily in _ensure_reader
+        # This is critical for multiprocessing safety
+        self.reader = None
+        self._reader_pid = None
+
+    def _ensure_reader(self):
+        """Ensure reader is valid in current process.
+
+        LMDB readers cannot be shared across forked processes, so we must
+        create a new reader in each worker process.
+        """
+        current_pid = os.getpid()
+        if self.reader is None or self._reader_pid != current_pid:
+            # Create reader in this process
+            from ..qmdb.reader import load
+            self.reader = load(
+                path=self.config.data_file,
+                image_dir=self.config.image_dir,
+                extra_path=self.config.extra_path,
+            )
+            self._reader_pid = current_pid
+
+    def __len__(self) -> int:
+        return len(self.keys)
+
+    def __getitem__(self, index: int) -> Dict[str, Any]:
+        """
+        Load and process a single sample.
+
+        Args:
+            index: Sample index
+
+        Returns:
+            Dict containing input_ids (tensor), attention_mask (tensor), labels (tensor),
+            and multimodal inputs (pixel_values, etc.)
+        """
+        _profiling = os.environ.get("PROFILE_DATALOADER")
+
+        # Ensure reader is valid (handles fork in multiprocessing)
+        self._ensure_reader()
+
+        key = self.keys[index]
+
+        if _profiling:
+            import time
+            _t0 = time.monotonic()
+
+        # Load raw data from QMDB
+        raw = self.reader.get(key)
+        if raw is None:
+            # Return empty sample if data not found
+            return self._empty_sample()
+
+        if _profiling:
+            _t_read = time.monotonic()
+
+        try:
+            # Extract multimodal data (images remain as PIL.Image)
+            images = self._extract_images(raw)
+            videos = self._extract_videos(raw)
+            audios: List = []
+
+            if _profiling:
+                _t_extract = time.monotonic()
+
+            # Build messages in sharegpt/alpaca format
+            prompt_messages, response_messages = self._build_messages(raw)
+
+            # Ensure <image> placeholders match the number of images
+            all_messages = prompt_messages + response_messages
+            all_messages = self._ensure_image_placeholders(all_messages, len(images))
+            prompt_messages = [m for m in all_messages if m["role"] != "assistant"]
+            response_messages = [m for m in all_messages if m["role"] == "assistant"]
+
+            # Process and tokenize
+            input_ids, labels = self._encode_example(
+                prompt=prompt_messages,
+                response=response_messages,
+                images=images,
+                videos=videos,
+                audios=audios,
+            )
+
+            if _profiling:
+                _t_tokenize = time.monotonic()
+
+            # Convert to tensors for ODB compatibility
+            # ODB requires input_ids to be a tensor with .size() method
+            input_ids_tensor = torch.tensor([input_ids], dtype=torch.long)
+            attention_mask_tensor = torch.ones_like(input_ids_tensor)
+            labels_tensor = torch.tensor([labels], dtype=torch.long)
+
+            result = {
+                "input_ids": input_ids_tensor,
+                "attention_mask": attention_mask_tensor,
+                "labels": labels_tensor,
+            }
+
+            # Process multimodal inputs using mm_plugin
+            # This is what the collator would normally do, but we do it here for ODB compatibility
+            if self.processor is not None and (images or videos):
+                mm_inputs = self.mm_plugin.get_mm_inputs(
+                    images=images,
+                    videos=videos,
+                    audios=audios,
+                    imglens=[len(images)],
+                    vidlens=[len(videos)],
+                    audlens=[0],
+                    batch_ids=[input_ids],  # Note: parameter name is batch_ids, not batch_input_ids
+                    processor=self.processor,
+                )
+                result.update(mm_inputs)
+                # Record total ViT patches for ODB vision-aware grouping
+                image_grid_thw = mm_inputs.get("image_grid_thw")
+                video_grid_thw = mm_inputs.get("video_grid_thw")
+                n_patches = 0
+                if image_grid_thw is not None:
+                    n_patches += int(image_grid_thw.prod(dim=1).sum().item())
+                if video_grid_thw is not None:
+                    n_patches += int(video_grid_thw.prod(dim=1).sum().item())
+                if n_patches > 0:
+                    result["odb_n_patches"] = n_patches
+
+                stat_dir = os.environ.get("ODB_STAT_PATCHES")
+                if stat_dir and n_patches > 0:
+                    wid = torch.utils.data.get_worker_info()
+                    wname = f"w{wid.id}" if wid else "main"
+                    stat_file = os.path.join(stat_dir, f"patches_{wname}.txt")
+                    with open(stat_file, "a") as sf:
+                        sf.write(f"{n_patches}\n")
+
+            if _profiling:
+                _t_mm = time.monotonic()
+                _getitem_prof = getattr(self, "_getitem_prof", None)
+                if _getitem_prof is None:
+                    _getitem_prof = {"tmdb_read": 0.0, "img_extract": 0.0, "tokenize": 0.0, "mm_process": 0.0, "count": 0}
+                    self._getitem_prof = _getitem_prof
+                _getitem_prof["tmdb_read"] += _t_read - _t0
+                _getitem_prof["img_extract"] += _t_extract - _t_read
+                _getitem_prof["tokenize"] += _t_tokenize - _t_extract
+                _getitem_prof["mm_process"] += _t_mm - _t_tokenize
+                _getitem_prof["count"] += 1
+                n = _getitem_prof["count"]
+                if n % 200 == 0:
+                    wid = torch.utils.data.get_worker_info()
+                    wname = f"w{wid.id}" if wid else "main"
+                    print(
+                        f"[GETITEM-PROF {wname}] n={n} "
+                        f"tmdb_read={_getitem_prof['tmdb_read']:.2f}s "
+                        f"img_extract={_getitem_prof['img_extract']:.2f}s "
+                        f"tokenize={_getitem_prof['tokenize']:.2f}s "
+                        f"mm_process={_getitem_prof['mm_process']:.2f}s "
+                        f"total={sum(v for k, v in _getitem_prof.items() if k != 'count'):.2f}s "
+                        f"avg={sum(v for k, v in _getitem_prof.items() if k != 'count') / n * 1000:.1f}ms/sample",
+                        flush=True,
+                    )
+
+            return result
+
+        except Exception as e:
+            # Log error and return empty sample
+            import warnings
+            import traceback
+            tb = traceback.format_exc()
+            warnings.warn(f"Error processing sample {key}: {e}\n{tb}")
+            # Print to stderr as well for visibility in logs
+            print(f"[LazyQMDBDataset] Error processing {key}: {e}", file=sys.stderr, flush=True)
+            return self._empty_sample()
+
+    def _empty_sample(self) -> Dict[str, Any]:
+        """Return an empty sample for error cases."""
+        bos_id = self.tokenizer.bos_token_id or 0
+        return {
+            "input_ids": torch.tensor([[bos_id]], dtype=torch.long),
+            "attention_mask": torch.tensor([[1]], dtype=torch.long),
+            "labels": torch.tensor([[IGNORE_INDEX]], dtype=torch.long),
+        }
+
+    def _extract_images(self, raw: Dict) -> List["ImageObject"]:
+        """
+        Extract images from raw data, keeping them as PIL.Image.
+
+        The QMDB reader's process() method already converts images to PIL.Image.
+        """
+        # Check multiple possible keys
+        images = raw.get(self.config.images_key) or raw.get("images") or raw.get("image")
+
+        if images is None:
+            return []
+
+        if not isinstance(images, list):
+            images = [images]
+
+        result = []
+        for img in images:
+            if isinstance(img, dict):
+                # QMDB reader returns {"image": PIL.Image, "path": ...}
+                if "image" in img:
+                    result.append(img["image"])
+            else:
+                # Direct PIL.Image
+                result.append(img)
+
+        return result
+
+    def _extract_videos(self, raw: Dict) -> List:
+        """Extract videos from raw data."""
+        video = raw.get(self.config.videos_key) or raw.get("video")
+
+        if video is None:
+            return []
+
+        if isinstance(video, dict):
+            # QMDB reader returns {"video": VideoReader, "path": ...} or {"images": [...], "path": ...}
+            if "images" in video:
+                # Video as image frames
+                return [video["images"]]
+            elif "video" in video:
+                return [video["video"]]
+            elif "gif" in video:
+                return [video["gif"]]
+
+        return [video] if video else []
+
+    def _build_messages(self, raw: Dict) -> tuple[List[Dict[str, str]], List[Dict[str, str]]]:
+        """
+        Build prompt and response messages from raw data.
+
+        Returns:
+            Tuple of (prompt_messages, response_messages)
+        """
+        if self.config.formatting == "sharegpt":
+            return self._build_sharegpt_messages(raw)
+        else:
+            return self._build_alpaca_messages(raw)
+
+    def _ensure_image_placeholders(
+        self, messages: List[Dict[str, str]], num_images: int
+    ) -> List[Dict[str, str]]:
+        """Ensure messages contain the correct number of <image> placeholders.
+
+        The mm_plugin.process_messages() requires one <image> per image.
+        TMDB data may not always include them in conversation text.
+        """
+        from ...extras.constants import IMAGE_PLACEHOLDER
+
+        existing_count = sum(m["content"].count(IMAGE_PLACEHOLDER) for m in messages)
+        missing = num_images - existing_count
+        if missing <= 0:
+            return messages
+
+        for m in messages:
+            if m["role"] == "user":
+                m["content"] = (IMAGE_PLACEHOLDER + "\n") * missing + m["content"]
+                break
+
+        return messages
+
+    def _build_sharegpt_messages(self, raw: Dict) -> tuple[List[Dict[str, str]], List[Dict[str, str]]]:
+        """Build messages from ShareGPT format."""
+        convs = raw.get(self.config.messages_key, [])
+
+        if not convs:
+            # Fallback: try common field names for prompt/response
+            query = raw.get("query", "") or raw.get("question", "") or raw.get("prompt", "")
+            response = (
+                raw.get("response", "") or raw.get("answer", "")
+                or raw.get("text", "") or raw.get("caption", "")
+                or raw.get("output", "")
+            )
+            if not query and self.config.prompt:
+                query = self.config.prompt
+            if query and response:
+                return (
+                    [{"role": "user", "content": str(query)}],
+                    [{"role": "assistant", "content": str(response)}]
+                )
+            return [], []
+
+        messages = []
+        for turn in convs:
+            role = turn.get(self.config.role_tag, turn.get("role", ""))
+            content = turn.get(self.config.content_tag, turn.get("content", ""))
+
+            if role in (self.config.user_tag, "user", "human"):
+                messages.append({"role": "user", "content": str(content)})
+            elif role in (self.config.assistant_tag, "assistant", "gpt", "bot"):
+                messages.append({"role": "assistant", "content": str(content)})
+            elif role in (self.config.system_tag, "system"):
+                # Insert system message at the beginning
+                messages.insert(0, {"role": "system", "content": str(content)})
+
+        # Split into prompt (all but last) and response (last assistant message)
+        if not messages:
+            return [], []
+
+        # Find the last assistant message
+        last_assistant_idx = -1
+        for i in range(len(messages) - 1, -1, -1):
+            if messages[i]["role"] == "assistant":
+                last_assistant_idx = i
+                break
+
+        if last_assistant_idx == -1:
+            # No assistant message, treat all as prompt
+            return messages, []
+
+        prompt = messages[:last_assistant_idx]
+        response = [messages[last_assistant_idx]]
+
+        return prompt, response
+
+    def _build_alpaca_messages(self, raw: Dict) -> tuple[List[Dict[str, str]], List[Dict[str, str]]]:
+        """Build messages from Alpaca format."""
+        instruction = raw.get(self.config.instruction_key, "")
+        input_text = raw.get(self.config.input_key, "")
+        output = raw.get(self.config.output_key, "")
+
+        # Use fixed prompt if specified
+        if self.config.prompt:
+            instruction = self.config.prompt
+
+        # Combine instruction and input
+        if input_text:
+            user_content = f"{instruction}\n{input_text}".strip()
+        else:
+            user_content = str(instruction)
+
+        prompt = [{"role": "user", "content": user_content}]
+        response = [{"role": "assistant", "content": str(output)}]
+
+        return prompt, response
+
+    def _encode_example(
+        self,
+        prompt: List[Dict[str, str]],
+        response: List[Dict[str, str]],
+        images: List["ImageObject"],
+        videos: List,
+        audios: List,
+    ) -> tuple[List[int], List[int]]:
+        """
+        Encode a single example using mm_plugin and template.
+
+        This follows the same logic as SupervisedDatasetProcessor._encode_data_example
+        but adapted for single-sample processing.
+        """
+        if not prompt or not response:
+            return [self.tokenizer.bos_token_id or 0], [IGNORE_INDEX]
+
+        # Combine prompt and response for message processing
+        messages = prompt + response
+
+        # Use mm_plugin to process messages (inserts vision tokens like <|vision_start|>...)
+        messages = self.mm_plugin.process_messages(
+            messages, images, videos, audios, self.processor
+        )
+
+        # Get initial token ids from mm_plugin (for vision tokens)
+        input_ids, labels = self.mm_plugin.process_token_ids(
+            [], [], images, videos, audios, self.tokenizer, self.processor
+        )
+
+        # Encode using template
+        encoded_pairs = self.template.encode_multiturn(
+            self.tokenizer, messages, system=None, tools=None
+        )
+
+        # Process encoded pairs
+        total_length = len(input_ids) + (1 if self.template.efficient_eos else 0)
+
+        if self.mask_history:
+            encoded_pairs = encoded_pairs[::-1]
+
+        for turn_idx, (source_ids, target_ids) in enumerate(encoded_pairs):
+            if total_length >= self.cutoff_len:
+                break
+
+            source_len, target_len = self._infer_seqlen(
+                len(source_ids), len(target_ids), self.cutoff_len - total_length
+            )
+            source_ids = source_ids[:source_len]
+            target_ids = target_ids[:target_len]
+            total_length += source_len + target_len
+
+            # Build labels
+            if self.train_on_prompt:
+                source_label = source_ids
+            elif self.template.efficient_eos and turn_idx != 0:
+                source_label = [self.tokenizer.eos_token_id] + [IGNORE_INDEX] * (source_len - 1)
+            else:
+                source_label = [IGNORE_INDEX] * source_len
+
+            if self.mask_history and turn_idx != 0:
+                target_label = [IGNORE_INDEX] * target_len
+            else:
+                target_label = target_ids
+
+            # Append to input_ids and labels
+            if self.mask_history:
+                input_ids = source_ids + target_ids + input_ids
+                labels = source_label + target_label + labels
+            else:
+                input_ids = input_ids + source_ids + target_ids
+                labels = labels + source_label + target_label
+
+        # Add EOS if efficient_eos
+        if self.template.efficient_eos:
+            input_ids = input_ids + [self.tokenizer.eos_token_id]
+            labels = labels + [self.tokenizer.eos_token_id]
+
+        return input_ids, labels
+
+    @staticmethod
+    def _infer_seqlen(source_len: int, target_len: int, max_len: int) -> tuple[int, int]:
+        """Infer sequence lengths for source and target."""
+        if source_len + target_len <= max_len:
+            return source_len, target_len
+
+        if source_len < max_len // 2:
+            return source_len, max_len - source_len
+
+        if target_len < max_len // 2:
+            return max_len - target_len, target_len
+
+        return max_len // 2, max_len - max_len // 2
+
+
+class ConcatLazyDataset(Dataset):
+    """
+    Concatenate multiple LazyQMDBDataset instances.
+
+    Supports weighted sampling based on dataset weights.
+    """
+
+    def __init__(self, datasets: List[LazyQMDBDataset]):
+        """
+        Initialize concatenated dataset.
+
+        Args:
+            datasets: List of LazyQMDBDataset instances
+        """
+        self.datasets = datasets
+        self.cumulative_sizes = []
+
+        cumsum = 0
+        for ds in datasets:
+            cumsum += len(ds)
+            self.cumulative_sizes.append(cumsum)
+
+    def __len__(self) -> int:
+        return self.cumulative_sizes[-1] if self.cumulative_sizes else 0
+
+    def __getitem__(self, index: int) -> Dict[str, Any]:
+        """Get item from the appropriate sub-dataset."""
+        if index < 0:
+            if -index > len(self):
+                raise IndexError("Index out of range")
+            index = len(self) + index
+
+        # Find which dataset this index belongs to
+        dataset_idx = 0
+        for i, size in enumerate(self.cumulative_sizes):
+            if index < size:
+                dataset_idx = i
+                break
+
+        # Calculate index within the sub-dataset
+        if dataset_idx == 0:
+            sample_idx = index
+        else:
+            sample_idx = index - self.cumulative_sizes[dataset_idx - 1]
+
+        return self.datasets[dataset_idx][sample_idx]
+
+
+class InterleavedLazyDataset(Dataset):
+    """
+    Interleaved dataset that samples from multiple datasets based on probabilities.
+
+    This is useful for mixing datasets with different weights during training.
+    """
+
+    def __init__(
+        self,
+        datasets: List[LazyQMDBDataset],
+        probabilities: Optional[List[float]] = None,
+        seed: int = 42,
+    ):
+        """
+        Initialize interleaved dataset.
+
+        Args:
+            datasets: List of LazyQMDBDataset instances
+            probabilities: Sampling probabilities for each dataset (normalized automatically)
+            seed: Random seed for reproducibility
+        """
+        self.datasets = datasets
+        self.rng = random.Random(seed)
+
+        # Calculate probabilities from weights if not provided
+        if probabilities is None:
+            weights = [ds.config.weight for ds in datasets]
+            total_weight = sum(weights)
+            self.probabilities = [w / total_weight for w in weights]
+        else:
+            total_prob = sum(probabilities)
+            self.probabilities = [p / total_prob for p in probabilities]
+
+        # Pre-compute total length (sum of all datasets)
+        self._total_len = sum(len(ds) for ds in datasets)
+
+    def __len__(self) -> int:
+        return self._total_len
+
+    def __getitem__(self, index: int) -> Dict[str, Any]:
+        """
+        Get item by sampling from datasets based on probabilities.
+
+        Note: The index is used to seed the RNG for deterministic sampling,
+        ensuring reproducibility across epochs.
+        """
+        # Use index to get deterministic but varied dataset selection
+        local_rng = random.Random(index)
+        ds_idx = local_rng.choices(range(len(self.datasets)), weights=self.probabilities)[0]
+
+        # Get sample index within the selected dataset
+        sample_idx = index % len(self.datasets[ds_idx])
+
+        return self.datasets[ds_idx][sample_idx]
