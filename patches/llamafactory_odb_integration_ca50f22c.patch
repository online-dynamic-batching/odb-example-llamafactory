+from typing import Optional, List, Dict, Set
+import os
+import glob
+from collections import OrderedDict
+import lmdb
+
+
+LMDB_EXTS = {'.lmdb', '.mdb'}
+
+
+def alphanum_path_key(s: str):
+    """Use to sort string by numbers in it, useful when numbers in string are not matched in digit (1 and 001)."""
+    s = os.path.splitext(s)[0]
+    digit_key_list = []
+    str_section = ''
+    is_digit = False
+    for c in s:
+        if c.isdigit() == is_digit:
+            str_section += c
+        else:
+            if is_digit:
+                digit_key_list.append(int(str_section))
+            else:
+                digit_key_list.append(str_section)
+            str_section, is_digit = c, c.isdigit()
+    if is_digit:
+        digit_key_list.append(int(str_section))
+    else:
+        digit_key_list.append(str_section)
+    return digit_key_list
+
+
+class LMDBData:
+    def __init__(self, path: str, env: lmdb.Environment):
+        self.path = path
+        self.env = env
+
+        self._keys_file = self.path + '-keys'
+        self.keys = self._init_keys()
+        self._keys_buffer = []
+        self._has_pop_keys = False
+
+        self._txn = None
+        if self.readonly:
+            self._txn = self.txn
+
+    @property
+    def txn(self):
+        if self._txn is None:
+            self._txn = self.env.begin(write=not self.readonly)
+        return self._txn
+
+    @staticmethod
+    def open(path: str, map_size: int = 4*1024*1024*1024,
+             subdir: Optional[bool] = None, readonly: bool = True, *args, max_dbs=128, **kwargs):
+        subdir = bool(subdir)
+        assert subdir is False, "'subdir' must be None or False."
+
+        env = lmdb.Environment(path, map_size, subdir, readonly, *args, max_dbs=max_dbs, **kwargs)
+
+        return LMDBData(path, env)
+
+    def _init_keys(self):
+        if os.path.exists(self._keys_file):
+            with open(self._keys_file) as f:
+                keys = f.read().splitlines()
+        else:
+            keys = None
+
+        txn = self.env.begin(write=False)
+        if keys is None or len(keys) != txn.stat()['entries']:
+            keys = []
+            for k in txn.cursor().iternext(values=False):
+                keys.append(k.decode('utf-8'))
+            with open(self._keys_file, 'w') as f:
+                f.writelines(k + '\n' for k in keys)
+        else:
+            txn.abort()
+
+        keys = OrderedDict((k, None) for k in keys)
+
+        return keys
+
+    def get(self, key: str, default=None):
+        return self.txn.get(key.encode(), default)
+
+    def put(self, key: str, value: bytes, *, overwrite=True, append=False, **kwargs):
+        if key in self.keys:
+            if not overwrite:
+                raise KeyError(f"Key already exists when not overwrite: {key}")
+            flag = 2
+        else:
+            flag = 1
+
+        rt = self.txn.put(key.encode(), value, overwrite=overwrite, append=append, **kwargs)
+
+        if not rt:
+            raise RuntimeError(f"Failed to put {key} to lmdb")
+
+        if flag == 1:
+            self.keys[key] = None
+            self._keys_buffer.append(key)
+
+        return flag
+
+    def pop(self, key: str):
+        self.txn.pop(key.encode())
+        self.keys.pop(key)
+        self._has_pop_keys = True
+
+    def commit(self):
+        if self._txn is not None:
+            self._txn.commit()
+            self._txn = None
+
+        if self._has_pop_keys:
+            with open(self._keys_file, 'w') as f:
+                f.writelines(k + '\n' for k in self.keys)
+        else:
+            with open(self._keys_file, 'a') as f:
+                f.writelines(k + '\n' for k in self._keys_buffer)
+
+        self.abort()
+
+    def abort(self):
+        if self._txn is not None:
+            self._txn.abort()
+            self._txn = None
+        self._keys_buffer.clear()
+        self._has_pop_keys = False
+
+    @property
+    def readonly(self):
+        return self.env.flags()['readonly']
+
+    def close(self):
+        self.abort()
+        self.env.close()
+
+    def __len__(self):
+        return self.env.stat()['entries']
+
+    def __del__(self):
+        self.close()
+
+
+class ExtendLMDBData:
+    def __init__(self, path: str, datas: List[LMDBData], map_size: int):
+        self.path = path
+        self.datas = datas
+        self.map_size = map_size
+        self._buffer = []
+
+        self.mapping = self._init_mapping()
+
+    @classmethod
+    def open(cls, path: str, map_size: int = 4*1024*1024*1024, subdir: Optional[bool] = None, readonly: bool = True,
+             *args, exts: Optional[Set[str]] = None, **kwargs):
+        paths = cls._parse_path(path, exts)
+        datas = [LMDBData.open(p, map_size, subdir, readonly, *args, **kwargs) for p in paths]
+
+        return cls(path, datas, map_size)
+
+    @classmethod
+    def dump(cls, data: Dict[str, bytes], path: str, map_size: int = 4*1024*1024*1024,
+             subdir: Optional[bool] = None, readonly: bool = False, *args, commit_size=256, **kwargs):
+        assert isinstance(data, dict), f"dump data must be a dictionary, rather than a {type(data)}."
+        for value in data.values():
+            assert isinstance(value, dict), f"value in data must be a dictionary, rather than a {type(value)}."
+
+        lmdbs = cls.open(path, map_size, subdir, readonly, *args, **kwargs)
+
+        commit_size_ = commit_size - 1
+        for i, (key, value) in enumerate(data.items()):
+            lmdbs.put(key, value, append=True)
+            if i % commit_size == commit_size_:
+                lmdbs.commit(append=True)
+        lmdbs.commit(append=True)
+        lmdbs.abort()
+
+    @classmethod
+    def _parse_path(cls, path: str, exts: Optional[Set[str]] = None):
+        if exts is None:
+            exts = LMDB_EXTS
+
+        if isinstance(path, list):
+            paths = path
+        elif glob.has_magic(path):
+            paths = sorted(glob.glob(path), key=alphanum_path_key)
+        elif not os.path.exists(path):
+            paths = [cls._create_path(path)]
+        elif os.path.isdir(path):
+            paths = sorted(glob.glob(os.path.join(path, '*')), key=alphanum_path_key)
+            paths = [p for p in paths if os.path.splitext(p)[1] in exts]
+        else:
+            paths = [path]
+
+        if not len(paths):
+            raise FileNotFoundError(f"Cannot find lmdb data files in path: {path}.")
+
+        return paths
+
+    @staticmethod
+    def _create_path(path: str):
+        ext = os.path.splitext(path)[1]
+        if ext == '':
+            folder = path
+            file = os.path.join(path, 'data.lmdb')
+        else:
+            folder = os.path.dirname(path)
+            file = path
+
+        if not os.path.exists(folder):
+            os.mkdir(folder)
+
+        return file
+
+    def _init_mapping(self):
+        mapping = {}
+        _counts = {}
+        for i, data in enumerate(self.datas):
+            for k in data.keys:
+                n = _counts.get(k, 0)
+                _counts[k] = n + 1
+                k = (k, n) if n else k
+                mapping[k] = i
+
+        return mapping
+
+    def _extend_lmdb(self):
+        assert not self.readonly, "Failed to extend_lmdb, cannot extend in readonly mode."
+        assert len(self.datas) > 0, "Failed to extend_lmdb, no existing lmdb."
+        path = self.path if os.path.isfile(self.path) else self.datas[0].path
+        index = len(self.datas)
+
+        _buffer = self._buffer.copy()
+        self.abort()
+
+        dn, fn = os.path.split(path)
+        fn, ext = os.path.splitext(fn)
+        path = f"{dn}/{fn}-{index}{ext}"
+
+        data = LMDBData.open(path, map_size=self.map_size, subdir=False, readonly=False)
+        self.datas.append(data)
+
+        for key, value in _buffer:
+            self.put(key, value, append=True)
+
+        return index
+
+    def get(self, key: str, default=None) -> Dict[str, bytes]:
+        data_index = self.mapping.get(key, None)
+        if data_index is None:
+            return default
+        if isinstance(key, tuple):
+            key = key[0]
+        record = self.datas[data_index].get(key, default=default)
+
+        return record
+
+    def put(self, key: str, value: bytes, *, overwrite: bool = True, append: bool = False, **kwargs) -> int:
+        if append:
+            data_index = len(self.datas) - 1
+        else:
+            data_index = self.mapping.get(key, None)
+            if data_index is None:
+                data_index = len(self.datas) - 1
+        data = self.datas[data_index]
+
+        try:
+            flag = data.put(key, value, overwrite=overwrite, append=False, **kwargs)
+        except lmdb.MapFullError:
+            if not append:
+                raise
+            data_index = self._extend_lmdb()
+            data = self.datas[data_index]
+            flag = data.put(key, value, overwrite=overwrite, append=False, **kwargs)
+
+        if flag == 1:
+            self.mapping[key] = data_index
+            self._buffer.append((key, value))
+
+        return flag
+
+    def pop(self, key: str):
+        data_index = self.mapping.get(key, None)
+        if data_index is None:
+            raise KeyError(f"Pop key not found: {key}")
+        self.datas[data_index].pop(key)
+
+    def commit(self, append: bool = False):
+        for data in self.datas[:-1]:
+            data.commit()
+        try:
+            self.datas[-1].commit()
+        except lmdb.MapFullError:
+            if not append:
+                raise
+            self._extend_lmdb()
+            self.datas[-1].commit()
+        self._buffer.clear()
+
+    def abort(self):
+        for data in self.datas:
+            data.abort()
+        self._buffer.clear()
+
+    def keys(self):
+        return self.mapping.keys()
+
+    @property
+    def readonly(self):
+        return all(data.readonly for data in self.datas)
+
+    def close(self):
+        self.abort()
+        for data in self.datas:
+            data.close()
+
+    def __len__(self):
+        return sum(len(data) for data in self.datas)
+
+    def __del__(self):
+        self.close()
+
+
+LMDBS = ExtendLMDBData
