+def _load_oracle_lengths_cache(cache_path: str) -> dict:
+    """Load oracle length cache and enforce v2 schema (defense in depth).
+
+    Functional metadata validation (template / cutoff_len / image_max_pixels / ...) lives
+    in `data.loader.validate_oracle_cache` since it needs full data_args/model_args; this
+    layer only verifies the cache is loadable, has expected basic shape, and is v2.
+    """
+    import json
+
+    with open(cache_path, "r") as f:
+        cache_data = json.load(f)
+
+    version = cache_data.get("version", 1)
+    if version < 2:
+        raise ValueError(
+            f"Oracle cache at {cache_path} is version {version}; v1 caches lack the "
+            "preprocess_config snapshot needed for safe loading. Regenerate with "
+            "the matching oracle-cache precompute utility (writes v2)."
+        )
+
+    if "lengths" not in cache_data or not isinstance(cache_data["lengths"], list):
+        raise ValueError(f"Oracle cache at {cache_path} missing 'lengths' list field")
+
+    return cache_data
+
+
+def resolve_oracle_lengths(dataset, full_lengths: List[int], cache_path: str) -> List[int]:
+    """Resolve oracle full-dataset lengths to a list aligned with the (possibly Subset) dataset.
+
+    Args:
+        dataset: The dataset that the sampler will index into (may be torch.utils.data.Subset
+                 if val_size split was applied).
+        full_lengths: Lengths of the original (pre-split) dataset, indexed 0..N-1.
+        cache_path: Cache path string, only used in error messages for diagnostics.
+
+    Returns:
+        A list of length `len(dataset)` whose i-th entry is the token length of `dataset[i]`.
+
+    Raises:
+        ValueError if the cache size doesn't match the underlying dataset size, with a
+        descriptive diff. We use ValueError (not assert) so `python -O` cannot skip it.
+    """
+    from torch.utils.data import Subset
+
+    from ...extras import logging
+
+    logger = logging.get_logger(__name__)
+
+    if isinstance(dataset, Subset):
+        underlying_len = len(dataset.dataset)
+        if len(full_lengths) != underlying_len:
+            raise ValueError(
+                f"Oracle cache size mismatch: cache={cache_path} has "
+                f"{len(full_lengths)} lengths but underlying dataset has "
+                f"{underlying_len} samples (diff={len(full_lengths) - underlying_len}). "
+                "Regenerate the oracle cache against the current dataset."
+            )
+        lengths = [full_lengths[i] for i in dataset.indices]
+        logger.info_rank0(
+            f"oracle lengths resolved: full={len(full_lengths)}, used={len(lengths)} "
+            f"(Subset=True, dataset_len={len(dataset)})"
+        )
+        return lengths
+
+    if len(full_lengths) != len(dataset):
+        raise ValueError(
+            f"Oracle cache size mismatch: cache={cache_path} has "
+            f"{len(full_lengths)} lengths but dataset has {len(dataset)} samples "
+            f"(diff={len(full_lengths) - len(dataset)}). "
+            "Regenerate the oracle cache against the current dataset."
+        )
+    logger.info_rank0(
+        f"oracle lengths resolved: full={len(full_lengths)}, used={len(full_lengths)} "
+        f"(Subset=False, dataset_len={len(dataset)})"
+    )
+    return full_lengths
+
