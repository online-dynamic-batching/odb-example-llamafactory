+# Unless required by applicable law or agreed to in writing, software
+# distributed under the License is distributed on an "AS IS" BASIS,
+# WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+# See the License for the specific language governing permissions and
+# limitations under the License.
+
+"""
+Simple collator for lazy QMDB datasets.
+
+This collator is designed to work with ODB/OLG DataLoaders where the dataset
+already returns fully processed tensor data.
+"""
+
+from typing import TYPE_CHECKING, Any, Dict, List, Optional
+
+import torch
+import torch.nn.functional as F
+
+try:
+    from odb.constants import TOTAL_BATCH_SIZE_KEY as ODB_TOTAL_BATCH_SIZE_KEY
+except Exception:
+    ODB_TOTAL_BATCH_SIZE_KEY = "total_batch_size"
+
+
+if TYPE_CHECKING:
+    from transformers import PreTrainedTokenizer
+
+
+class SimpleCollator:
+    """
+    Simple collator that pads and batches tensor data.
+
+    This collator expects the dataset to return data with:
+    - input_ids: tensor of shape (1, seq_len)
+    - attention_mask: tensor of shape (1, seq_len)
+    - labels: tensor of shape (1, seq_len)
+    - Optional multimodal inputs (pixel_values, etc.)
+
+    This is designed for use with ODB/OLG DataLoaders where complex
+    multimodal processing is already done in the dataset.
+    """
+
+    def __init__(
+        self,
+        tokenizer: "PreTrainedTokenizer",
+        pad_to_multiple_of: int = 8,
+        compute_dtype: Optional["torch.dtype"] = None,
+    ):
+        self.tokenizer = tokenizer
+        self.pad_to_multiple_of = pad_to_multiple_of
+        self.padding_side = tokenizer.padding_side
+        self.pad_token_id = tokenizer.pad_token_id or 0
+        self.label_pad_token_id = -100
+        self.compute_dtype = compute_dtype
+
+    def __call__(self, features: List[Dict[str, Any]]) -> Dict[str, torch.Tensor]:
+        """
+        Collate a batch of features.
+
+        Args:
+            features: List of feature dicts from the dataset
+
+        Returns:
+            Batched and padded tensors
+        """
+        if not features:
+            return {}
+
+        # Debug: Log batch composition
+        import os
+        if os.environ.get("DEBUG_LAZY_DATASET"):
+            n_with_pv = sum(1 for f in features if f.get("pixel_values") is not None)
+            n_total = len(features)
+            print(f"[SimpleCollator] batch_size={n_total}, samples_with_pixel_values={n_with_pv}")
+
+        # Filter out invalid features (empty input_ids)
+        valid_features = []
+        for f in features:
+            input_ids = f.get("input_ids")
+            if input_ids is None:
+                continue
+            if isinstance(input_ids, torch.Tensor):
+                # Squeeze to get actual sequence length
+                if input_ids.dim() > 1:
+                    seq_len = input_ids.size(-1)  # last dim is seq_len
+                else:
+                    seq_len = input_ids.size(0)
+                if seq_len == 0 or input_ids.numel() == 0:
+                    continue
+            elif isinstance(input_ids, (list, tuple)):
+                if len(input_ids) == 0:
+                    continue
+            valid_features.append(f)
+
+        # If all features were invalid, return empty dict
+        # This should be handled by the training loop
+        if not valid_features:
+            import warnings
+            warnings.warn(
+                "SimpleCollator received batch with all empty input_ids, returning empty dict"
+            )
+            return {}
+
+        features = valid_features
+
+        # Extract total_batch_size if present (for ODB)
+        total_batch_size = None
+        for feature in features:
+            if ODB_TOTAL_BATCH_SIZE_KEY in feature and feature[ODB_TOTAL_BATCH_SIZE_KEY] is not None:
+                total_batch_size = feature.pop(ODB_TOTAL_BATCH_SIZE_KEY)
+            elif ODB_TOTAL_BATCH_SIZE_KEY in feature:
+                feature.pop(ODB_TOTAL_BATCH_SIZE_KEY)
+
+        # Get the keys from the first feature
+        batch = {}
+
+        # Handle input_ids, attention_mask, labels
+        for key in ["input_ids", "attention_mask", "labels"]:
+            if key not in features[0]:
+                continue
+
+            tensors = [f[key] for f in features]
+
+            # Squeeze if needed (remove batch dim from individual samples)
+            tensors = [t.squeeze(0) if t.dim() > 1 else t for t in tensors]
+
+            # Find max length
+            max_len = max(t.size(0) for t in tensors)
+
+            # Pad to multiple
+            if self.pad_to_multiple_of:
+                max_len = ((max_len + self.pad_to_multiple_of - 1) //
+                          self.pad_to_multiple_of) * self.pad_to_multiple_of
+
+            # Determine padding value
+            if key == "labels":
+                pad_value = self.label_pad_token_id
+            elif key == "attention_mask":
+                pad_value = 0
+            else:
+                pad_value = self.pad_token_id
+
+            # Pad tensors
+            padded = []
+            for t in tensors:
+                pad_len = max_len - t.size(0)
+                if pad_len > 0:
+                    if self.padding_side == "right":
+                        t = F.pad(t, (0, pad_len), value=pad_value)
+                    else:
+                        t = F.pad(t, (pad_len, 0), value=pad_value)
+                padded.append(t)
+
+            batch[key] = torch.stack(padded)
+
+        # Handle other keys (multimodal inputs like pixel_values, grid_sizes, etc.)
+        first_feature = features[0]
+        for key in first_feature:
+            if key in ["input_ids", "attention_mask", "labels"]:
+                continue
+
+            values = [f.get(key) for f in features if key in f]
+            if not values:
+                continue
+
+            # Filter out None values
+            values = [v for v in values if v is not None]
+            if not values:
+                continue
+
+            # If all values are tensors, try to stack/cat them
+            if all(isinstance(v, torch.Tensor) for v in values):
+                # Check for empty tensors
+                non_empty = [v for v in values if v.numel() > 0]
+                if not non_empty:
+                    continue
+                try:
+                    # Try to concatenate along batch dimension
+                    batch[key] = torch.cat(non_empty, dim=0)
+                except RuntimeError:
+                    # If shapes don't match, keep as list
+                    batch[key] = non_empty
+            elif all(isinstance(v, list) for v in values):
+                # Flatten lists, filter out empty
+                flat = sum(values, [])
+                if flat:
+                    batch[key] = flat
+            else:
+                # Keep as list, filter out None
+                batch[key] = [v for v in values if v is not None]
+
+        # Add total_batch_size for ODB gradient scaling
+        if total_batch_size is not None:
+            batch[ODB_TOTAL_BATCH_SIZE_KEY] = total_batch_size
+
+        # Ensure multimodal keys are always present for Qwen3VL compatibility
+        # Even if all samples are text-only, we should explicitly set these to None
+        # to maintain consistent batch structure across DDP ranks
+        multimodal_keys = ["pixel_values", "image_grid_thw", "pixel_values_videos", "video_grid_thw"]
+        for mm_key in multimodal_keys:
+            if mm_key not in batch:
+                batch[mm_key] = None
+
+        # Final validation: ensure input_ids has non-zero sequence length
+        if "input_ids" in batch:
+            input_ids = batch["input_ids"]
+            if isinstance(input_ids, torch.Tensor):
+                # Check if sequence length is 0
+                if input_ids.dim() >= 2 and input_ids.size(-1) == 0:
+                    import warnings
+                    warnings.warn(
+                        f"SimpleCollator produced batch with zero sequence length: {input_ids.shape}, "
+                        "returning empty dict"
+                    )
+                    return {}
+                if input_ids.numel() == 0:
+                    import warnings
+                    warnings.warn(
+                        f"SimpleCollator produced empty input_ids tensor: {input_ids.shape}, "
+                        "returning empty dict"
+                    )
+                    return {}
+
+        # Convert floating point tensors to compute_dtype for consistency with SFTDataCollatorWith4DAttentionMask
+        # This ensures pixel_values and other float tensors use the same dtype as the JSON data path
+        if self.compute_dtype is not None:
+            for key, value in batch.items():
+                if torch.is_tensor(value) and torch.is_floating_point(value):
+                    batch[key] = value.to(self.compute_dtype)
+
+        return batch
+
+
+def create_simple_collator(
+    tokenizer: "PreTrainedTokenizer",
+    pad_to_multiple_of: int = 8,
+    compute_dtype: Optional["torch.dtype"] = None,
+) -> SimpleCollator:
+    """
+    Create a simple collator for lazy QMDB datasets.
+
+    This collator is designed for use with ODB/OLG DataLoaders where
+    the dataset already returns fully processed tensor data.
+
+    Args:
+        tokenizer: Tokenizer for padding configuration
+        pad_to_multiple_of: Pad sequences to multiple of this value
+        compute_dtype: Target dtype for floating point tensors (e.g., torch.bfloat16).
+                       If provided, all float tensors will be converted to this dtype.
+                       This ensures consistency with SFTDataCollatorWith4DAttentionMask.
+
+    Returns:
+        Configured SimpleCollator
+    """
+    return SimpleCollator(
+        tokenizer=tokenizer,
+        pad_to_multiple_of=pad_to_multiple_of,
+        compute_dtype=compute_dtype,
+    )
