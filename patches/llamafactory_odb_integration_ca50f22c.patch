+class _ProfilingDataLoaderWrapper:
+    """Wraps a DataLoader to measure per-batch fetch time and collate time."""
+
+    def __init__(self, dataloader, use_odb=False, output_dir=None, num_params=None):
+        self._dataloader = dataloader
+        self._use_odb = use_odb
+        self._output_dir = output_dir
+        self._num_params = num_params
+        # Forward all attributes to the underlying dataloader
+        self.dataset = dataloader.dataset
+
+    def __getattr__(self, name):
+        return getattr(self._dataloader, name)
+
+    def __len__(self):
+        return len(self._dataloader)
+
+    def __iter__(self):
+        import sys
+        import time
+        import torch.distributed as dist
+
+        rank = dist.get_rank() if dist.is_initialized() else 0
+        mode = "ODB" if self._use_odb else "Standard"
+
+        total_dl_wait = 0.0
+        total_compute = 0.0
+        batch_count = 0
+        start_time = time.monotonic()
+
+        try:
+            for batch in self._dataloader:
+                t_batch_ready = time.monotonic()
+                if batch_count > 0:
+                    # dl_wait = time from generator resume (trainer done) to next batch ready
+                    total_dl_wait += t_batch_ready - _t_after_yield
+                    # compute = time from yield to generator resume (trainer forward/backward/step)
+                    total_compute += _t_after_yield - _t_before_yield
+                batch_count += 1
+
+                # Periodic logging
+                if batch_count % 10 == 0:
+                    elapsed = time.monotonic() - start_time
+                    n = max(batch_count - 1, 1)
+                    sys.stderr.write(
+                        f"[DL-PROF {mode} rank{rank}] batch={batch_count} "
+                        f"elapsed={elapsed:.1f}s "
+                        f"dl_wait={total_dl_wait:.2f}s({total_dl_wait / elapsed * 100:.1f}%) "
+                        f"compute={total_compute:.2f}s({total_compute / elapsed * 100:.1f}%) "
+                        f"avg_dl_wait={total_dl_wait / n * 1000:.0f}ms "
+                        f"avg_compute={total_compute / n * 1000:.0f}ms\n"
+                    )
+                    sys.stderr.flush()
+
+                _t_before_yield = time.monotonic()
+                yield batch
+                _t_after_yield = time.monotonic()
+        finally:
+            elapsed = time.monotonic() - start_time
+            other_s = elapsed - total_dl_wait - total_compute
+            n = max(batch_count - 1, 1)
+            sys.stderr.write(
+                f"[DL-PROF-FINAL {mode} rank{rank}] batches={batch_count} "
+                f"elapsed={elapsed:.1f}s "
+                f"dl_wait={total_dl_wait:.2f}s({total_dl_wait / max(elapsed, 0.001) * 100:.1f}%) "
+                f"compute={total_compute:.2f}s({total_compute / max(elapsed, 0.001) * 100:.1f}%) "
+                f"other={other_s:.2f}s({other_s / max(elapsed, 0.001) * 100:.1f}%) "
+                f"avg_dl_wait={total_dl_wait / n * 1000:.0f}ms "
+                f"avg_compute={total_compute / n * 1000:.0f}ms\n"
+            )
+            sys.stderr.flush()
+            if rank == 0 and self._output_dir:
+                import json
+                import os
+                prof_data = {
+                    "mode": mode,
+                    "batches": batch_count,
+                    "elapsed_s": round(elapsed, 2),
+                    "total_dl_wait_s": round(total_dl_wait, 2),
+                    "total_compute_s": round(total_compute, 2),
+                    "other_s": round(other_s, 2),
+                    "pipeline_overlap": round(total_compute / max(total_dl_wait + total_compute, 0.001), 4),
+                    "num_params": self._num_params,
+                }
+                path = os.path.join(self._output_dir, "dl_prof.json")
+                try:
+                    with open(path, "w") as f:
+                        json.dump(prof_data, f, indent=2)
+                except OSError:
+                    pass
+
+
+def _wrap_dataloader_profiling(dataloader, use_odb=False, output_dir=None, num_params=None):
+    """Wrap a DataLoader with profiling instrumentation."""
