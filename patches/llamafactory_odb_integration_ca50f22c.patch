+"""
+Configuration classes and parsing utilities for QMDB datasets.
+"""
+
+import os
+from dataclasses import dataclass, field
+from typing import Any, Dict, List, Literal, Optional
+
+import yaml
+
+
+@dataclass
+class QMDBDatasetConfig:
+    """Configuration for a single QMDB dataset."""
+
+    # Required fields
+    name: str
+    data_file: str  # Path to tmdb/lmdb directory or file
+
+    # Optional paths
+    image_dir: Optional[str] = None
+    extra_path: Optional[str] = None  # Extra lmdb for images
+
+    # Data format
+    formatting: Literal["alpaca", "sharegpt"] = "sharegpt"
+
+    # Sampling
+    max_samples: Optional[int] = None  # Maximum number of samples to use (None = all)
+    weight: float = 1.0  # Weight for mixing datasets
+
+    # Fixed prompt (for some tasks like OCR)
+    prompt: Optional[str] = None
+
+    # Column/field mapping
+    messages_key: str = "conversations"
+    images_key: str = "images"
+    videos_key: str = "video"
+
+    # Alpaca format keys
+    instruction_key: str = "instruction"
+    input_key: str = "input"
+    output_key: str = "output"
+
+    # ShareGPT format tags
+    role_tag: str = "from"
+    content_tag: str = "value"
+    user_tag: str = "human"
+    assistant_tag: str = "gpt"
+    system_tag: str = "system"
+
+    def __post_init__(self):
+        """Validate configuration after initialization."""
+        if not self.data_file:
+            raise ValueError(f"data_file is required for dataset '{self.name}'")
+
+        if self.weight <= 0:
+            raise ValueError(f"weight must be positive for dataset '{self.name}'")
+
+        if self.max_samples is not None and self.max_samples <= 0:
+            raise ValueError(f"max_samples must be positive for dataset '{self.name}'")
+
+
+@dataclass
+class QMDBLoaderConfig:
+    """Configuration for QMDB data loading."""
+
+    # Dataset configurations
+    datasets: List[QMDBDatasetConfig] = field(default_factory=list)
+
+    # ODB (Online Dynamic Batch) mode
+    use_odb: bool = False
+    defer_odb_apply_to_trainer: bool = False
+
+    # ODB version: 1 = original (odb.py), 11 = v1 + shutdown fixes (odb1_1.py),
+    # 2 = bug-fixed (odb2.py), 3 = v2 + join_mode (odb3.py),
+    # 4 = v3 + max-based cross-rank group alignment (odb4.py)
+    odb_version: int = 1
+
+    # ODB join mode: when True + odb_version=3, finished rank StopIteration independently
+    odb_join_mode: bool = False
+
+    # ODB DDP loss-scaling strategy. See DataArguments.odb_loss_scaling_mode.
+    # One of: "sample", "token_approx", "token_exact".
+    odb_loss_scaling_mode: str = "sample"
+
+    # ODB ablation flags
+    odb_no_warmup: bool = False
+    odb_no_sync: bool = False
+    odb_buffer_size: int | None = None
+    odb_max_patches: int = 0
+
+    # ODB specific
+    max_input_length: int = 8192
+
+    # ODB buffer settings
+    buffer_factor: float = 0.9
+
+    # Sorted Batching
+    use_sorted_batching: bool = False
+    use_hf_group_by_length: bool = False
+
+    # Token-budget batch sampling (GMT/BMT) - mutually exclusive with use_odb and length-grouped baselines
+    use_global_max_tokens: bool = False
+    use_bucketed_max_tokens: bool = False
+    max_tokens_budget: int = 8192
+    max_tokens_bucket_size: int = 4096
+    max_tokens_oracle_cache: str | None = None
+
+    # Data processing
+    cutoff_len: int = 2048
+    preprocessing_num_workers: int = 4
+
+    def __post_init__(self):
+        """Validate configuration after initialization."""
+        if not self.datasets:
+            raise ValueError("At least one dataset is required")
+
+        if self.max_input_length <= 0:
+            raise ValueError("max_input_length must be positive")
+
+        if not 0 < self.buffer_factor <= 1:
+            raise ValueError("buffer_factor must be in (0, 1]")
+
+        enabled_batch_modes = sum(
+            bool(x)
+            for x in (
+                self.use_odb,
+                self.use_sorted_batching,
+                self.use_hf_group_by_length,
+                self.use_global_max_tokens,
+                self.use_bucketed_max_tokens,
+            )
+        )
+        if enabled_batch_modes > 1:
+            raise ValueError(
+                "Batching modes are mutually exclusive: use_odb, use_sorted_batching, "
+                "use_hf_group_by_length, use_global_max_tokens, use_bucketed_max_tokens."
+            )
+
+
+def parse_qmdb_config(config_path: str) -> QMDBLoaderConfig:
+    """
+    Parse QMDB configuration from a YAML file.
+
+    Args:
+        config_path: Path to the YAML configuration file
+
+    Returns:
+        QMDBLoaderConfig object with all dataset configurations
+
+    Example YAML format:
+    ```yaml
+    dataloader_type: odb
+    max_input_length: 8192
+    cutoff_len: 2048
+
+    datasets:
+      - name: ShareCaptioner
+        data_file: /path/to/tmdb
+        image_dir: /path/to/images
+        formatting: sharegpt
+        weight: 1.0
+
+      - name: synthdog-en
+        data_file: /path/to/tmdb
+        formatting: sharegpt
+        prompt: "Recognize text in the image"
+        max_samples: 100000
+    ```
+    """
+    if not os.path.exists(config_path):
+        raise FileNotFoundError(f"Config file not found: {config_path}")
+
+    with open(config_path, "r", encoding="utf-8") as f:
+        raw_config = yaml.safe_load(f)
+
+    if raw_config is None:
+        raise ValueError(f"Empty config file: {config_path}")
+
+    # Parse datasets
+    datasets = []
+    raw_datasets = raw_config.pop("datasets", [])
+
+    for ds_config in raw_datasets:
+        if isinstance(ds_config, dict):
+            datasets.append(QMDBDatasetConfig(**ds_config))
+        else:
+            raise ValueError(f"Invalid dataset config: {ds_config}")
+
+    # Parse loader config
+    loader_config = QMDBLoaderConfig(
+        datasets=datasets,
+        use_odb=raw_config.pop("use_odb", False),
+        odb_version=raw_config.pop("odb_version", 1),
+        max_input_length=raw_config.pop("max_input_length", raw_config.pop("odb_max_input_length", 8192)),
+        buffer_factor=raw_config.pop("buffer_factor", 0.9),
+        use_sorted_batching=raw_config.pop("use_sorted_batching", False),
+        use_hf_group_by_length=raw_config.pop("use_hf_group_by_length", False),
+        use_global_max_tokens=raw_config.pop("use_global_max_tokens", False),
+        use_bucketed_max_tokens=raw_config.pop("use_bucketed_max_tokens", False),
+        max_tokens_budget=raw_config.pop("max_tokens_budget", 8192),
+        max_tokens_bucket_size=raw_config.pop("max_tokens_bucket_size", 4096),
+        max_tokens_oracle_cache=raw_config.pop("max_tokens_oracle_cache", None),
+        cutoff_len=raw_config.pop("cutoff_len", 2048),
+        preprocessing_num_workers=raw_config.pop("preprocessing_num_workers", 4),
+    )
+
+    # Warn about unknown keys
+    if raw_config:
+        import warnings
+        warnings.warn(f"Unknown config keys: {list(raw_config.keys())}")
+
+    return loader_config
+
+
+def parse_qmdb_yaml_datasets(yaml_path: str) -> List[QMDBDatasetConfig]:
+    """
+    Parse datasets from the qqmm-style YAML format (train_s0_datasets.yaml).
+
+    This format uses nested categories:
+    ```yaml
+    Caption:
+      ShareCaptioner:
+        data_file: /path/to/tmdb
+        image_dir: /path/to/images
+
+    OCR:
+      synthdog-en:
+        data_file: /path/to/tmdb
+        prompt: 'Recognize text'
+    ```
+
+    Args:
+        yaml_path: Path to the YAML file
+
+    Returns:
+        List of QMDBDatasetConfig objects
+    """
+    if not os.path.exists(yaml_path):
+        raise FileNotFoundError(f"YAML file not found: {yaml_path}")
+
+    with open(yaml_path, "r", encoding="utf-8") as f:
+        raw_config = yaml.safe_load(f)
+
+    if raw_config is None:
+        return []
+
+    datasets = []
+
+    for category, category_datasets in raw_config.items():
+        if not isinstance(category_datasets, dict):
+            continue
+
+        for name, ds_config in category_datasets.items():
+            if ds_config is None:
+                continue
+            if not isinstance(ds_config, dict):
+                continue
+
+            # Build full name with category prefix if needed
+            full_name = f"{category}/{name}" if "/" not in name else name
+
+            # Map yaml keys to config keys
+            config_dict = {
+                "name": full_name,
+                "data_file": ds_config.get("data_file"),
+                "image_dir": ds_config.get("image_dir"),
+                "extra_path": ds_config.get("extra_path"),
+                "prompt": ds_config.get("prompt"),
+                "max_samples": ds_config.get("max_samples"),
+                "weight": ds_config.get("weight", 1.0),
+                "formatting": ds_config.get("formatting", "sharegpt"),
+            }
+
+            # Remove None values
+            config_dict = {k: v for k, v in config_dict.items() if v is not None}
+
+            try:
+                datasets.append(QMDBDatasetConfig(**config_dict))
+            except (TypeError, ValueError) as e:
+                import warnings
+                warnings.warn(f"Skipping invalid dataset '{full_name}': {e}")
+                continue
+
+    return datasets
+
+
+def create_default_config(
+    data_file: str,
+    name: Optional[str] = None,
+    image_dir: Optional[str] = None,
+    **kwargs
+) -> QMDBDatasetConfig:
+    """
+    Create a QMDBDatasetConfig with sensible defaults.
+
+    Args:
+        data_file: Path to the QMDB data file
+        name: Dataset name (defaults to basename of data_file)
+        image_dir: Path to image directory
+        **kwargs: Additional configuration options
+
+    Returns:
+        QMDBDatasetConfig object
+    """
+    if name is None:
+        name = os.path.basename(data_file.rstrip("/"))
+
+    return QMDBDatasetConfig(
+        name=name,
+        data_file=data_file,
+        image_dir=image_dir,
+        **kwargs
+    )
