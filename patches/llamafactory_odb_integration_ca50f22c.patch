+def validate_oracle_cache(
+    cache_path: str,
+    data_args: "DataArguments",
+    model_args: "ModelArguments",
+    template: "Template",
+    tokenizer: "PreTrainedTokenizer",
+    processor: Optional["ProcessorMixin"] = None,
+) -> None:
+    """Verify a v2 oracle cache was produced under settings compatible with the current run.
+
+    Raises ValueError on:
+      - missing / unreadable cache file
+      - v1 cache (lacks preprocess_config; cannot be safely validated)
+      - any hard-validated field mismatch
+
+    Hard-validated fields (mismatch -> raise):
+        dataset, template, default_system (template-effective), cutoff_len,
+        mask_history, train_on_prompt, image_max_pixels, image_min_pixels,
+        tokenizer_class, tokenizer_vocab_size, processor_class,
+        image_processor_class, image_processor_patch_size, image_processor_merge_size
+
+    Diagnostic-only (recorded but not validated): model_name_or_path
+        Reason: 2B/8B Qwen3-VL share tokenizer/processor; storage paths differ
+        but yield identical input_ids. Functional checks above are sufficient.
+    """
+    import json as _json
+
+    if not os.path.exists(cache_path):
+        raise ValueError(f"Oracle cache not found: {cache_path}")
+
+    with open(cache_path, "r") as f:
+        cache_data = _json.load(f)
+
+    version = cache_data.get("version", 1)
+    if version < 2:
+        raise ValueError(
+            f"Oracle cache at {cache_path} is version {version}; v1 caches lack the "
+            "preprocess_config snapshot needed for safe validation. Regenerate with "
+            "the matching oracle-cache precompute utility (writes v2)."
+        )
+
+    cache_cfg = cache_data.get("preprocess_config")
+    if not isinstance(cache_cfg, dict):
+        raise ValueError(
+            f"Oracle cache at {cache_path} missing 'preprocess_config' field "
+            "(should be present in v2). Regenerate the cache."
+        )
+
+    # Build current-run snapshot using the same shape as the precompute script.
+    img_proc = getattr(processor, "image_processor", None) if processor is not None else None
+    current_cfg = {
+        "dataset": data_args.dataset,
+        "template": data_args.template,
+        "default_system": template.default_system,  # template-effective value
+        "cutoff_len": data_args.cutoff_len,
+        "mask_history": getattr(data_args, "mask_history", False),
+        "train_on_prompt": getattr(data_args, "train_on_prompt", False),
+        "image_max_pixels": getattr(model_args, "image_max_pixels", None),
+        "image_min_pixels": getattr(model_args, "image_min_pixels", None),
+        "tokenizer_class": type(tokenizer).__name__,
+        "tokenizer_vocab_size": getattr(tokenizer, "vocab_size", None),
+        "processor_class": type(processor).__name__ if processor is not None else None,
+        "image_processor_class": type(img_proc).__name__ if img_proc is not None else None,
+        "image_processor_patch_size": getattr(img_proc, "patch_size", None),
+        "image_processor_merge_size": getattr(img_proc, "merge_size", None),
+    }
+
+    mismatches = []
+    for key, expected in current_cfg.items():
+        cached = cache_cfg.get(key, "<MISSING>")
+        if cached != expected:
+            mismatches.append((key, expected, cached))
+
+    if mismatches:
+        details = "\n".join(
+            f"  - {k}: current={cur!r}, cache={cache!r}" for k, cur, cache in mismatches
+        )
+        raise ValueError(
+            f"Oracle cache {cache_path} mismatch with current run "
+            f"(cache 'model_diag'={cache_data.get('model_diag', {})}):\n{details}\n"
+            "The cache must be regenerated against the current dataset/template/model "
+            "settings via the matching oracle-cache precompute utility."
+        )
+
+    logger.info_rank0(
+        f"Oracle cache {cache_path} passed validation "
+        f"(n={cache_data.get('num_samples')}, sha256={cache_data.get('lengths_sha256', '?')[:12]}...)"
+    )
+
+
+def _get_tmdb_dataset_from_attrs(
+    tmdb_attrs: list["DatasetAttr"],
+    template: "Template",
+    model_args: "ModelArguments",
+    data_args: "DataArguments",
+    training_args: "Seq2SeqTrainingArguments",
+    tokenizer: "PreTrainedTokenizer",
+    processor: Optional["ProcessorMixin"] = None,
+) -> "DatasetModule":
+    """
+    Get lazy-loading TMDB dataset from DatasetAttr list (new path via dataset_info.json).
+
+    This function converts DatasetAttr objects to QMDBDatasetConfig objects and
+    reuses the existing lazy QMDB dataloader infrastructure.
+    """
+    from .lazy import create_lazy_collator
+    from .lazy.config import QMDBLoaderConfig
+    from .lazy.loader import _create_dataloader, _create_datasets, dataset_attr_to_qmdb_config
+
+    logger.info_rank0(f"Loading TMDB datasets via dataset_info.json: {[str(a) for a in tmdb_attrs]}")
+
+    # Convert DatasetAttr to QMDBDatasetConfig
+    configs = [dataset_attr_to_qmdb_config(attr) for attr in tmdb_attrs]
+
+    # Debug log for alignment testing: print full QMDBDatasetConfig
+    for cfg in configs:
+        logger.info_rank0(
+            f"[TMDB via dataset_info] QMDBDatasetConfig: name={cfg.name}, data_file={cfg.data_file}, "
+            f"formatting={cfg.formatting}, max_samples={cfg.max_samples}, weight={cfg.weight}, "
+            f"image_dir={cfg.image_dir}, extra_path={cfg.extra_path}, prompt={cfg.prompt}, "
+            f"messages_key={cfg.messages_key}, images_key={cfg.images_key}, "
+            f"role_tag={cfg.role_tag}, content_tag={cfg.content_tag}, "
+            f"user_tag={cfg.user_tag}, assistant_tag={cfg.assistant_tag}"
+        )
+
+    # Build loader config
+    defer_odb_apply_to_trainer = bool(data_args.use_odb and data_args.odb_version == 51)
+    loader_config = QMDBLoaderConfig(
+        datasets=configs,
+        use_odb=data_args.use_odb,
+        defer_odb_apply_to_trainer=defer_odb_apply_to_trainer,
+        odb_version=data_args.odb_version,
+        odb_join_mode=data_args.odb_join_mode,
+        odb_loss_scaling_mode=data_args.odb_loss_scaling_mode,
+        odb_no_warmup=data_args.odb_no_warmup,
+        odb_no_sync=data_args.odb_no_sync,
+        odb_buffer_size=data_args.odb_buffer_size,
+        max_input_length=data_args.odb_max_input_length,
+        cutoff_len=data_args.cutoff_len,
+        use_sorted_batching=data_args.use_sorted_batching,
+        use_hf_group_by_length=data_args.use_hf_group_by_length,
+        use_global_max_tokens=data_args.use_global_max_tokens,
+        use_bucketed_max_tokens=data_args.use_bucketed_max_tokens,
+        max_tokens_budget=data_args.max_tokens_budget,
+        max_tokens_bucket_size=data_args.max_tokens_bucket_size,
+        max_tokens_oracle_cache=data_args.max_tokens_oracle_cache,
+    )
+
+    # Create datasets (reuse existing infrastructure)
+    datasets = _create_datasets(
+        configs=configs,
+        template=template,
+        tokenizer=tokenizer,
+        processor=processor,
+        cutoff_len=data_args.cutoff_len,
+        train_on_prompt=data_args.train_on_prompt,
+        mask_history=data_args.mask_history,
+    )
+
+    # Combine datasets
+    from .lazy.dataset import ConcatLazyDataset
+
+    if len(datasets) == 1:
+        dataset = datasets[0]
+    else:
+        dataset = ConcatLazyDataset(datasets)
+
+    # Split train/eval if val_size is specified
+    eval_dataset = None
+    if data_args.val_size > 1e-6:
+        import numpy as np
+        from torch.utils.data import Subset
+
+        total_len = len(dataset)
+        val_size = int(data_args.val_size) if data_args.val_size > 1 else int(total_len * data_args.val_size)
+        val_size = max(1, min(val_size, total_len - 1))  # at least 1 sample for each split
+
+        # Deterministic split using training seed
+        rng = np.random.default_rng(training_args.seed)
+        indices = rng.permutation(total_len)
+        eval_indices = indices[:val_size].tolist()
+        train_indices = indices[val_size:].tolist()
+
+        eval_dataset = Subset(dataset, eval_indices)
+        dataset = Subset(dataset, train_indices)
+
+        logger.info_rank0(
+            f"Split TMDB dataset: train={len(train_indices)}, eval={len(eval_indices)} "
+            f"(val_size={data_args.val_size}, seed={training_args.seed})"
+        )
+
+    # Validate oracle cache (when an oracle length baseline is enabled) before constructing
+    # the dataloader. Mismatches between the cache's preprocess_config and the current
+    # data_args/model_args raise ValueError; v1 caches are rejected outright.
+    if (
+        (
+            data_args.use_global_max_tokens
+            or data_args.use_bucketed_max_tokens
+            or data_args.use_hf_group_by_length
+        )
+        and data_args.max_tokens_oracle_cache
+    ):
+        validate_oracle_cache(
+            cache_path=data_args.max_tokens_oracle_cache,
+            data_args=data_args,
+            model_args=model_args,
+            template=template,
+            tokenizer=tokenizer,
+            processor=processor,
+        )
+
+    # Create collator
+    collator = create_lazy_collator(
+        template=template,
+        tokenizer=tokenizer,
+        processor=processor,
+        model=None,  # Will be set by Trainer
+    )
+
+    # Create dataloader (reuse existing infrastructure)
+    dataloader = _create_dataloader(
+        dataset=dataset,
+        loader_config=loader_config,
+        training_args=training_args,
+        collator=collator,
+        tokenizer=tokenizer,
+        compute_dtype=model_args.compute_dtype,
+    )
+
+    dataloader_type = "odb" if data_args.use_odb else "standard"
+    logger.info_rank0(
+        f"Created TMDB lazy dataloader (via dataset_info) with type '{dataloader_type}', "
+        f"dataset size: {len(dataloader.dataset)}, dataloader len: {len(dataloader)}, "
+        f"sampler: {type(dataloader.sampler).__name__}"
+    )
+
+    # Return as DatasetModule (same format as _get_qmdb_lazy_dataset)
+    dataset_module = {
+        "train_dataset": dataloader.dataset,
+        "_lazy_dataloader": dataloader,
+        "_lazy_collator": collator,
+        "_use_odb": data_args.use_odb,
+        "_enable_odb_with_package": defer_odb_apply_to_trainer,
+        "_odb_max_input_length": data_args.odb_max_input_length,
+        "_odb_version": data_args.odb_version,
+        "_odb_join_mode": data_args.odb_join_mode,
+        "_odb_loss_scaling_mode": data_args.odb_loss_scaling_mode,
+        "_odb_no_warmup": data_args.odb_no_warmup,
+        "_odb_no_sync": data_args.odb_no_sync,
+        "_odb_buffer_size": data_args.odb_buffer_size,
+        "_odb_max_patches": data_args.odb_max_patches,
+    }
+
+    if eval_dataset is not None:
+        dataset_module["eval_dataset"] = eval_dataset
+
+    return dataset_module
