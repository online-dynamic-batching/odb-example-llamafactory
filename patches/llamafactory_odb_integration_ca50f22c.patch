+def _create_datasets(
+    configs: List[QMDBDatasetConfig],
+    template: "Template",
+    tokenizer: "PreTrainedTokenizer",
+    processor: Optional["ProcessorMixin"] = None,
+    cutoff_len: int = 2048,
+    train_on_prompt: bool = False,
+    mask_history: bool = False,
+) -> List[LazyQMDBDataset]:
+    """
+    Create LazyQMDBDataset instances from configurations.
+
+    Args:
+        configs: List of dataset configurations
+        template: LlamaFactory template
+        tokenizer: Tokenizer
+        processor: Multimodal processor
+        cutoff_len: Maximum sequence length
+        train_on_prompt: Whether to compute loss on prompts
+        mask_history: Whether to mask history turns
+
+    Returns:
+        List of LazyQMDBDataset instances
+    """
+    from ...extras import logging
+
+    logger = logging.get_logger(__name__)
+
+    datasets = []
+    for config in configs:
+        try:
+            ds = LazyQMDBDataset(
+                config=config,
+                template=template,
+                tokenizer=tokenizer,
+                processor=processor,
+                cutoff_len=cutoff_len,
+                train_on_prompt=train_on_prompt,
+                mask_history=mask_history,
+            )
+            datasets.append(ds)
+            logger.info_rank0(f"Loaded lazy dataset '{config.name}' with {len(ds)} samples")
+        except Exception as e:
+            import traceback
+            logger.warning_rank0(f"Failed to load dataset '{config.name}': {e}")
+            logger.warning_rank0(f"Traceback: {traceback.format_exc()}")
+            continue
+
+    if not datasets:
+        raise RuntimeError("No datasets were successfully loaded")
+
+    return datasets
